# --------------------------------------------------------------------------
# Subscriptions (link lists and validated Xray JSON pools; scheduled refresh)
# --------------------------------------------------------------------------
sub_hwid() {
    # stable random UUID per install; NOT derived from any hardware identifier
    if [ ! -s "$SUB_HWID_FILE" ]; then
        mkdir -p "$SUB_DIR"; chmod 700 "$SUB_DIR"
        _id="$(py -c 'import uuid;print(uuid.uuid4())' 2>/dev/null)"
        [ -n "$_id" ] || _id="$(cat /proc/sys/kernel/random/uuid 2>/dev/null)"
        [ -n "$_id" ] || fatal "could not generate an HWID"
        printf '%s' "$_id" | atomic_write "$SUB_HWID_FILE" 600 || fatal "could not store HWID"
    fi
    cat "$SUB_HWID_FILE"
}

# Fetch a given URL into a candidate catalog file (does NOT touch stored state).
# Secrets (URL, HWID) are passed via mode-600 files, never on the command line.
# Temp files live in the per-command private run directory.
# Args: <url> <dest-catalog-file>. Returns 0 and writes dest on success.
sub_fetch_to() {
    _f_url="$1"; _f_dest="$2"
    mkdir -p "$SUB_DIR" || { err "could not create $SUB_DIR"; return 1; }
    chmod 700 "$SUB_DIR" 2>/dev/null || true
    ensure_run_dir
    _fetch_dir="$RUN_DIR/subfetch"; rm -rf "$_fetch_dir"; mkdir -m 700 "$_fetch_dir"
    _f_urlf="$_fetch_dir/url"; _f_err="$_fetch_dir/error"; _f_cat="$_fetch_dir/catalog"
    printf '%s' "$_f_url" | atomic_write "$_f_urlf" 600 \
        || { err "could not stage URL"; return 1; }
    sub_hwid >/dev/null || { err "could not prepare HWID"; return 1; }
    if py "$MKSUB" fetch --url-file "$_f_urlf" --hwid-file "$SUB_HWID_FILE" --ua "$SUB_USER_AGENT" \
            > "$_f_cat" 2>"$_f_err" && [ -s "$_f_cat" ]; then
        chmod 600 "$_f_cat"
        if mv -f "$_f_cat" "$_f_dest"; then
            rm -rf "$_fetch_dir"
            return 0
        fi
        err "could not write catalog"
    else
        _f_message=""
        IFS= read -r _f_message < "$_f_err" || true
        err "${_f_message#mksub: error: }"
    fi
    rm -rf "$_fetch_dir"
    return 1
}

sub_add() {
    [ -n "${1:-}" ] || fatal "a subscription URL is required"
    case "$1" in https://*) : ;; *) fatal "subscription URL must start with https://" ;; esac
    mkdir -p "$SUB_DIR"; chmod 700 "$SUB_DIR"
    txn_begin
    c_grn "Fetching subscription..."
    # Fetch to a candidate catalog FIRST; only commit the URL + catalog (and clear
    # any previous selection) once we have a valid non-empty result. A failed add
    # therefore never replaces a working subscription with a broken one.
    ensure_run_dir; _cand="$RUN_DIR/new-catalog.json"
    if ! sub_fetch_to "$1" "$_cand"; then
        rm -f "$_cand"
        fatal "subscription not added (fetch/parse failed)"
    fi
    # commit URL + catalog only after a valid candidate exists; check every write
    printf '%s' "$1" | atomic_write "$SUB_URL_FILE" 600 || fatal "could not store subscription URL"
    atomic_write "$SUB_CATALOG" 600 < "$_cand" || fatal "could not store catalog"
    rm -f "$SUB_SELECTED" "$SUB_SELECTED_META"
    enable_refresh_timer || fatal "subscription stored, but automatic refresh timer could not be enabled"
    txn_commit
    c_grn "Subscription added."
    sub_list
}

sub_list() {
    [ -f "$SUB_CATALOG" ] || fatal "no subscription catalog yet (menu -> Manage a multi-server subscription -> Refresh)"
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    PROXY_UNIFI_TERMINAL_SAFE_EMOJI=1 py "$MKSUB" render --file "$SUB_CATALOG" --selected "$_sel"
}

sub_select() {
    [ -n "${1:-}" ] || fatal "a node number is required"
    case "$1" in ""|*[!0-9]*) fatal "select takes a node NUMBER from the subscription list";; esac
    [ -f "$SUB_CATALOG" ] || fatal "no catalog yet (refresh the subscription first)"
    txn_begin
    ensure_run_dir
    _meta="$RUN_DIR/selection.json"
    _payload="$RUN_DIR/selection.payload"
    _row="$(py "$MKSUB" extract --file "$SUB_CATALOG" --index "$1" \
        --meta-file "$_meta" --payload-file "$_payload" 2>/dev/null)" \
        || fatal "no node #$1 in the subscription"
    _id="${_row%%"$TAB"*}"; _row="${_row#*"$TAB"}"
    _ok="${_row%%"$TAB"*}"; _row="${_row#*"$TAB"}"
    _reason="${_row%%"$TAB"*}"; _kind="${_row#*"$TAB"}"
    [ "$_ok" = "1" ] || fatal "node #$1 is unsupported${_reason:+ ($_reason)}"
    [ -z "$_reason" ] || c_ylw "Provider profile warning: $_reason"
    if [ "$_kind" = "pool" ]; then
        # JSON balancer/pool profile: extract its raw JSON and import via the
        # -confdir balancer path (builds + validates + applies, state-safe).
        _FROM_SUB=1 _QUIET=1 cmd_import_json "$_payload"
    else
        # single share link: reuse the hardened single-link path.
        _link=""
        IFS= read -r _link < "$_payload" || [ -n "$_link" ] \
            || fatal "selected node payload is empty"
        _FROM_SUB=1 _QUIET=1 cmd_import "$_link"
    fi
    # record the selection only after a successful import; check the write
    mkdir -p "$SUB_DIR" || fatal "could not record selection"
    printf '%s' "$_id" | atomic_write "$SUB_SELECTED" 600 || fatal "could not record selection marker"
    atomic_write "$SUB_SELECTED_META" 600 < "$_meta" || fatal "could not record selection metadata"
    txn_commit
    [ "${_QUIET:-0}" = 1 ] || c_grn "Selected subscription node #$1 (id $_id)."
}

sub_refresh() {
    [ -s "$SUB_URL_FILE" ] || fatal "no subscription configured"
    ensure_run_dir; _candidate="$RUN_DIR/refreshed-catalog.json"
    sub_fetch_to "$(cat "$SUB_URL_FILE")" "$_candidate" \
        || { err "refresh failed; keeping the current catalog and tunnel"; return 1; }
    txn_begin
    atomic_write "$SUB_CATALOG" 600 < "$_candidate" || fatal "could not install refreshed catalog"
    [ "${_AUTO_REFRESH:-0}" = 1 ] || c_grn "Catalog refreshed."
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    if [ -z "$_sel" ] || [ ! -s "$SUB_SELECTED_META" ]; then
        txn_commit
        [ "${_AUTO_REFRESH:-0}" = 1 ] || sub_list
        return 0
    fi
    _new_meta="$RUN_DIR/refreshed-selection.json"
    _match_err="$RUN_DIR/refreshed-selection.err"
    if _match="$(py "$MKSUB" match --file "$SUB_CATALOG" --selection-file "$SUB_SELECTED_META" \
        --meta-file "$_new_meta" 2>"$_match_err")"; then
        _new_index="${_match%%"$TAB"*}"; _match_rest="${_match#*"$TAB"}"
        _new_id="${_match_rest%%"$TAB"*}"
        if [ "$_new_id" = "$_sel" ]; then
            atomic_write "$SUB_SELECTED_META" 600 < "$_new_meta" \
                || fatal "could not store refreshed selection metadata"
            txn_commit
            [ "${_AUTO_REFRESH:-0}" = 1 ] || info "selected node is unchanged."
        else
            _QUIET=1 sub_select "$_new_index"
            info "selected node changed; validated and applied refreshed provider configuration."
        fi
    else
        _match_rc=$?
        if [ "$_match_rc" != 1 ]; then
            _match_msg=""
            IFS= read -r _match_msg < "$_match_err" || true
            fatal "could not match selected subscription node${_match_msg:+ (${_match_msg#mksub: error: })}"
        fi
        txn_commit
        c_ylw "Selected node was removed or refresh matching was ambiguous; active tunnel kept unchanged."
    fi
}

sub_set_interval() {
    if ! _uint "$1" || [ "$1" -lt 1 ] || [ "$1" -gt 8760 ]; then
        fatal "refresh interval must be 1-8760 hours"
    fi
    txn_begin
    SUB_REFRESH_HOURS="$1"; save_settings
    enable_refresh_timer || fatal "could not update refresh timer"
    txn_commit
    c_grn "Automatic refresh interval set to ${SUB_REFRESH_HOURS}h."
}

sub_set_user_agent() {
    py - "$1" <<'PYEOF' || fatal "User-Agent must contain printable ASCII only and cannot include quotes or backslashes"
import sys
value = sys.argv[1]
if not value or len(value) > 120:
    raise SystemExit(1)
if any(ord(ch) < 0x20 or ord(ch) > 0x7e or ch in '"\\' for ch in value):
    raise SystemExit(1)
PYEOF
    txn_begin
    SUB_USER_AGENT="$1"; save_settings
    txn_commit
    c_grn "Subscription User-Agent updated. Refresh to test provider compatibility."
}

sub_remove() {
    txn_begin
    disable_refresh_timer
    rm -f "$SUB_URL_FILE" "$SUB_CATALOG" "$SUB_SELECTED" "$SUB_SELECTED_META"
    txn_commit
    c_ylw "Subscription removed (HWID kept). The active tunnel is unchanged."
    info "To also stop proxying, use the menu (Stop) or import a different link."
}

sub_status() {
    if [ ! -s "$SUB_URL_FILE" ]; then echo "subscription: (none)"; return; fi
    echo "subscription: configured"
    if [ -f "$SUB_CATALOG" ]; then
        py - "$SUB_CATALOG" <<'PYEOF' 2>/dev/null || true
import json,sys
c=json.load(open(sys.argv[1]))
m=c.get("meta",{})
print("nodes:        %s (%s supported)" % (m.get("count","?"), m.get("supported","?")))
if "interval_hours" in m: print("provider hint: refresh every %sh" % m["interval_hours"])
if "userinfo" in m: print("userinfo:     %s" % m["userinfo"])
PYEOF
    else
        echo "nodes:        (not fetched yet; refresh from the subscription menu)"
    fi
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    echo "selected:     ${_sel:-(none)}"
    echo "hwid:         $([ -s "$SUB_HWID_FILE" ] && echo set || echo unset)"
    echo "auto refresh: every ${SUB_REFRESH_HOURS}h"
    echo "user-agent:   $SUB_USER_AGENT"
}


cmd_uninstall() {
    need_root
    disable_refresh_timer
    systemctl disable --now "$SERVICE_NAME" 2>/dev/null || true
    _i=0
    while systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null && [ "$_i" -lt 20 ]; do
        sleep 0.25 2>/dev/null || sleep 1; _i=$((_i + 1))
    done
    systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null \
        && fatal "service is still running; refusing to remove its unit"
    systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
    fw_unlock                       # drop the userspace-core firewall guard, if any
    rm -f "$SERVICE_FILE" "$PLUGIN_SERVICE_FILE" "$REFRESH_SERVICE_FILE" "$REFRESH_TIMER_FILE" "$ONBOOT_DST"
    remove_proxy_link
    systemctl daemon-reload 2>/dev/null || true
    c_ylw "Removed service + boot hook. Data kept at $ROOT (delete it manually to purge keys/config)."
    c_ylw "Don't forget to delete the WireGuard VPN Client in the UniFi UI."
}

usage() {
    cat <<EOF
proxy - multi-core proxy/VPN client (xray-core + sing-box + AmneziaWG) for UniFi gateways

Run 'proxy' with no arguments for the interactive management menu — it is the
full interface: links, subscriptions, AmneziaWG profiles, WireGuard config, keys,
port/MTU/DNS, ping tests, autostart, updates, and uninstall.

Direct commands (quick ops / scripting):
  proxy start        Start the service
  proxy stop         Stop the service
  proxy restart      Restart the service
  proxy status       Show engine / server / listener status
  proxy ping [mode]  Test via get|head|tcp|icmp (default from settings)
  proxy logs [args]  Tail service logs (passes args to journalctl)
  proxy update       Update cores/assets with runtime rollback
  proxy geo-update   Update geo files with checksum + rollback
  proxy help         This help

Everything else lives in the menu (run 'proxy').
Data lives in $ROOT and survives reboots/firmware upgrades via unifi-common.
EOF
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------
cmd="${1:-}"
if [ $# -ge 1 ]; then shift; fi
case "$cmd" in
    ""|status|logs|ping|-h|--help|help|_fw-lock|_fw-unlock) : ;;
    *) need_root; acquire_lock; recover_transaction ;;
esac
load_settings
case "$cmd" in
    # interactive menu (default) — the menu is the full interface for everything:
    # import, subscriptions, keys, port/MTU/DNS, ping, autostart, update, uninstall.
    "")           cmd_menu ;;
    # kept direct commands (quick ops / scripting)
    start)        cmd_start ;;
    stop)         cmd_stop ;;
    restart)      cmd_restart ;;
    status)       cmd_status ;;
    logs)         cmd_logs logs "$@" ;;
    ping)         cmd_ping "${1:-}" ;;
    update)       cmd_update ;;
    geo-update)   cmd_geo_update ;;
    -h|--help|help) usage ;;
    # internal hooks (used only by install.sh, the boot hook, and the systemd
    # unit's ExecStartPre/ExecStopPost; not user-facing). _fw-lock is deliberately
    # fail-closed for sing-box/amnezia-box, while _fw-unlock is cleanup-only.
    install-binary)  cmd_install_binary ;;
    install-service) install_service ;;
    boot-recover)    boot_recover ;;
    sub-refresh-auto) _AUTO_REFRESH=1 sub_refresh ;;
    _fw-lock)        fw_lock ;;
    _fw-unlock)      fw_unlock ;;
    *) err "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
