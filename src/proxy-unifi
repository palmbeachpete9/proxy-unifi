    elif systemctl start "$SERVICE_NAME" 2>/dev/null;          then c_grn "Service started."
    else c_red "Failed to start - is a link imported? Check 'View logs'."; fi
}
menu_stop() {
    if ! systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Service is already stopped."
    elif systemctl stop "$SERVICE_NAME" 2>/dev/null;             then c_ylw "Service stopped."
    else c_red "Failed to stop service."; fi
}
menu_restart() {
    if systemctl restart "$SERVICE_NAME" 2>/dev/null; then c_grn "Service restarted."
    else c_red "Failed to restart - is a link imported? Check 'View logs'."; fi
}
menu_enable() {
    if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null || systemctl enable "$SERVICE_NAME" >/dev/null 2>&1; then
        if _save_autostart enabled; then c_grn "Autostart enabled."
        else c_red "Enabled, but could not persist the autostart marker."; fi
    else c_red "Failed to enable autostart (is the service installed?)."; fi
}
menu_disable() {
    if ! systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null || systemctl disable "$SERVICE_NAME" >/dev/null 2>&1; then
        if _save_autostart disabled; then c_ylw "Autostart disabled (service keeps running until stopped)."
        else c_red "Disabled, but could not persist the autostart marker."; fi
    else c_red "Failed to disable autostart."; fi
}

menu_set_ping() {
    load_settings
    _cur="$(printf '%s' "$PING_MODE" | tr '[:lower:]' '[:upper:]')"
    echo "Choose default ping protocol (currently selected: ${_cur}):"
    echo "  1. via proxy (GET)    - real delay through the proxy tunnel"
    echo "  2. via proxy (HEAD)   - same, HEAD request"
    echo "  3. TCP                - handshake latency to the server"
    echo "  4. ICMP               - echo to the server host"
    printf 'Choice [Enter = 1]: '
    read -r _p || true
    case "${_p:-1}" in
        1) _m="get" ;; 2) _m="head" ;; 3) _m="tcp" ;; 4) _m="icmp" ;;
        *) c_red "invalid choice"; return ;;
    esac
    cmd_set ping "$_m"
}

cmd_menu() {
    # Interactive loop: turn off errexit and run each action in a subshell so a
    # failing action (including any fatal/exit) reports its error and returns to
    # the menu instead of killing the whole program.
    set +e
    while true; do
        clear 2>/dev/null || true
        print_menu
        printf '\nPlease enter your selection [0-20]: '
        read -r sel || exit 0
        echo
        case "$sel" in
            0)  exit 0 ;;
            1)  ( menu_import ) ;;
            2)  ( cmd_config ) ;;
            3)  ( cmd_wg_config ) ;;
            4)  ( printf 'Regenerate keys? This breaks the current UniFi VPN Client until you re-paste the new config. [y/N]: '
                  read -r _c || true
                  if [ "${_c:-}" = "y" ]; then cmd_regen_keys; else c_ylw "Cancelled."; fi ) ;;
            5)  ( printf 'New WireGuard UDP port [%s]: ' "$WG_PORT"; read -r _v || true
                  if [ -n "${_v:-}" ]; then cmd_set port "$_v"; else c_ylw "Unchanged."; fi ) ;;
            6)  ( printf 'New tunnel MTU [%s]: ' "$WG_MTU"; read -r _v || true
                  if [ -n "${_v:-}" ]; then cmd_set mtu "$_v"; else c_ylw "Unchanged."; fi ) ;;
            7)  ( printf 'Tunnel DNS (comma-separated, empty to reset to 8.8.8.8) [%s]: ' "$INNER_DNS"; read -r _v || true
                  cmd_set dns "${_v:-}" ) ;;
            8)  ( cmd_ping ) ;;
            9)  ( menu_set_ping ) ;;
            10) ( menu_start ) ;;
            11) ( menu_stop ) ;;
            12) ( menu_restart ) ;;
            13) ( cmd_status ) ;;
            14) ( printf 'Lines to show [100]: '; read -r _n || true
                  case "${_n:-}" in ""|*[!0-9]*) _n=100 ;; esac
                  cmd_logs logs -n "$_n" --no-pager ) ;;
            15) ( menu_enable ) ;;
            16) ( menu_disable ) ;;
            17) ( cmd_update ) ;;
            18) ( cmd_geo_update ) ;;
            19) ( if [ -x "$XRAY" ]; then "$XRAY" version | head -1; else c_ylw "xray-core: not installed"; fi
                  echo "proxy-unifi CLI 1.0.0" ) ;;
            20) printf 'Really uninstall the service + boot hook? [y/N]: '; read -r _c || true
                if [ "${_c:-}" = "y" ]; then ( cmd_uninstall ); pause; exit 0; else c_ylw "Cancelled."; fi ;;
            *)  c_red "Invalid selection." ;;
        esac
        pause
    done
}

# Import-or-replace entry point: a direct share link, or a subscription.
menu_import() {
    echo "Import or replace connection link:"
    echo "  1. Paste a single proxy link (vless/vmess/trojan/ss/hysteria2/tuic)"
    echo "  2. Use a subscription (add / list / select / refresh)"
    echo "  3. Import an Xray JSON balancer/pool profile (from a file)"
    echo "  0. Back"
    printf 'Choice: '
    read -r _c || true
    echo
    case "${_c:-0}" in
        1) printf 'Paste proxy link: '; read -r _l || true
           if [ -n "${_l:-}" ]; then cmd_import "$_l"; else c_ylw "No link entered."; fi ;;
        2) menu_sub ;;
        3) menu_import_json ;;
        0|"") : ;;
        *) c_red "invalid choice" ;;
    esac
}

# Import a full Xray JSON profile (balancer / auto-select pool) from a file path.
menu_import_json() {
    echo "Provide the Xray JSON profile. Place the file on the gateway (e.g. via"
    echo "scp) and enter its path, or paste the JSON and end with a line of just EOF."
    printf 'File path (blank to paste instead): '
    read -r _p || true
    if [ -n "${_p:-}" ]; then
        [ -f "$_p" ] || { c_red "no such file: $_p"; return; }
        cmd_import_json "$_p"
        return
    fi
    _tmp="$(mktemp "$ETC_DIR/.paste.XXXXXX")" || { c_red "could not create temp file"; return; }
    # shellcheck disable=SC2064
    trap "rm -f '$_tmp'" EXIT INT TERM HUP
    echo "Paste JSON now; finish with a single line containing only: EOF"
    while IFS= read -r _line; do
        [ "$_line" = "EOF" ] && break
        printf '%s\n' "$_line" >> "$_tmp"
    done
    if [ -s "$_tmp" ]; then cmd_import_json "$_tmp"; else c_ylw "Nothing pasted."; fi
    rm -f "$_tmp"; trap - EXIT INT TERM HUP
}

# Interactive subscription submenu (wraps the cmd_sub actions).
menu_sub() {
    if [ -s "$SUB_URL_FILE" ]; then sub_status; echo; fi
    echo "Subscription:"
    echo "  1. Add / replace subscription URL"
    echo "  2. List nodes"
    echo "  3. Select node"
    echo "  4. Refresh"
    echo "  5. Remove"
    echo "  0. Back"
    printf 'Choice: '
    read -r _s || true
    echo
    case "${_s:-0}" in
        1) printf 'Subscription URL (https): '; read -r _u || true
           if [ -n "${_u:-}" ]; then sub_add "$_u"; else c_ylw "Cancelled."; fi ;;
        2) sub_list ;;
        3) sub_list; echo; printf 'Node number to select: '; read -r _n || true
           if [ -n "${_n:-}" ]; then sub_select "$_n"; else c_ylw "Cancelled."; fi ;;
        4) sub_refresh ;;
        5) printf 'Remove the subscription? [y/N]: '; read -r _c || true
           if [ "${_c:-}" = "y" ]; then sub_remove; else c_ylw "Cancelled."; fi ;;
        0|"") : ;;
        *) c_red "invalid choice" ;;
    esac
}

# --------------------------------------------------------------------------
# Subscriptions (Base64 / plain link-list; single subscription, manual refresh)
# --------------------------------------------------------------------------
sub_hwid() {
    # stable random UUID per install; NOT derived from any hardware identifier
    if [ ! -s "$SUB_HWID_FILE" ]; then
        mkdir -p "$SUB_DIR"; chmod 700 "$SUB_DIR"
        _id="$(py -c 'import uuid;print(uuid.uuid4())' 2>/dev/null)"
        [ -n "$_id" ] || _id="$(cat /proc/sys/kernel/random/uuid 2>/dev/null)"
        [ -n "$_id" ] || fatal "could not generate an HWID"
        printf '%s' "$_id" > "$SUB_HWID_FILE"; chmod 600 "$SUB_HWID_FILE"
    fi
    cat "$SUB_HWID_FILE"
}

# Fetch a given URL into a candidate catalog file (does NOT touch stored state).
# Secrets (URL, HWID) are passed via mode-600 files, never on the command line.
# Temp files live under $SUB_DIR (same filesystem as $SUB_CATALOG -> atomic mv);
# stderr goes to a private temp, never a shared /tmp path.
# Args: <url> <dest-catalog-file>. Returns 0 and writes dest on success.
# remove any stale temp files from a previously interrupted fetch
sub_clean_temps() { rm -f "$SUB_DIR"/.url.* "$SUB_DIR"/.err.* "$SUB_DIR"/.cat.* "$SUB_DIR"/.newcat.* 2>/dev/null || true; }

sub_fetch_to() {
    _f_url="$1"; _f_dest="$2"
    mkdir -p "$SUB_DIR" || { err "could not create $SUB_DIR"; return 1; }
    chmod 700 "$SUB_DIR" 2>/dev/null || true
    sub_clean_temps
    _f_urlf="$(mktemp "$SUB_DIR/.url.XXXXXX")" || { err "could not create temp file"; return 1; }
    _f_err="$(mktemp "$SUB_DIR/.err.XXXXXX")"  || { rm -f "$_f_urlf"; err "could not create temp file"; return 1; }
    _f_cat="$(mktemp "$SUB_DIR/.cat.XXXXXX")"  || { rm -f "$_f_urlf" "$_f_err"; err "could not create temp file"; return 1; }
    # token-bearing temp files must never survive an interrupt
    # shellcheck disable=SC2064
    trap "rm -f '$_f_urlf' '$_f_err' '$_f_cat'" EXIT INT TERM HUP
    chmod 600 "$_f_urlf"
    printf '%s' "$_f_url" > "$_f_urlf" || { trap - EXIT INT TERM HUP; rm -f "$_f_urlf" "$_f_err" "$_f_cat"; err "could not stage URL"; return 1; }
    sub_hwid >/dev/null || { trap - EXIT INT TERM HUP; rm -f "$_f_urlf" "$_f_err" "$_f_cat"; err "could not prepare HWID"; return 1; }
    if py "$MKSUB" fetch --url-file "$_f_urlf" --hwid-file "$SUB_HWID_FILE" \
            --ua "proxy-unifi (UniFi OS)" > "$_f_cat" 2>"$_f_err" && [ -s "$_f_cat" ]; then
        chmod 600 "$_f_cat"
        if mv -f "$_f_cat" "$_f_dest"; then
            rm -f "$_f_urlf" "$_f_err"
            trap - EXIT INT TERM HUP
            return 0
        fi
        err "could not write catalog"
    else
        err "$(head -1 "$_f_err" 2>/dev/null | sed 's/^mksub: error: //')"
    fi
    rm -f "$_f_urlf" "$_f_err" "$_f_cat"
    trap - EXIT INT TERM HUP
    return 1
}

# Refresh the stored subscription into its catalog (atomic).
sub_fetch() {
    [ -s "$SUB_URL_FILE" ] || fatal "no subscription configured (menu -> Import or replace -> subscription)"
    sub_fetch_to "$(cat "$SUB_URL_FILE")" "$SUB_CATALOG"
}

sub_add() {
    [ -n "${1:-}" ] || fatal "a subscription URL is required"
    case "$1" in https://*) : ;; *) fatal "subscription URL must start with https://" ;; esac
    mkdir -p "$SUB_DIR"; chmod 700 "$SUB_DIR"
    c_grn "Fetching subscription..."
    # Fetch to a candidate catalog FIRST; only commit the URL + catalog (and clear
    # any previous selection) once we have a valid non-empty result. A failed add
    # therefore never replaces a working subscription with a broken one.
    _cand="$(mktemp "$SUB_DIR/.newcat.XXXXXX")" || fatal "could not create temp file"
    if ! sub_fetch_to "$1" "$_cand"; then
        rm -f "$_cand"
        fatal "subscription not added (fetch/parse failed)"
    fi
    # commit URL + catalog only after a valid candidate exists; check every write
    printf '%s' "$1" > "$SUB_URL_FILE" || { rm -f "$_cand"; fatal "could not store subscription URL"; }
    chmod 600 "$SUB_URL_FILE"
    mv -f "$_cand" "$SUB_CATALOG" || { rm -f "$_cand"; fatal "could not store catalog"; }
    chmod 600 "$SUB_CATALOG"
    rm -f "$SUB_SELECTED"            # a new subscription invalidates the old selection
    c_grn "Subscription added."
    sub_list
}

sub_list() {
    [ -f "$SUB_CATALOG" ] || fatal "no subscription catalog yet (menu -> Import or replace -> subscription -> Refresh)"
    py "$MKSUB" render --file "$SUB_CATALOG"
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    [ -n "$_sel" ] && { echo; info "currently selected node id: $_sel"; } || true
}

sub_select() {
    [ -n "${1:-}" ] || fatal "a node number is required"
    case "$1" in ""|*[!0-9]*) fatal "select takes a node NUMBER from the subscription list";; esac
    [ -f "$SUB_CATALOG" ] || fatal "no catalog yet (refresh the subscription first)"
    _row="$(py "$MKSUB" get --file "$SUB_CATALOG" --index "$1" 2>/dev/null)" \
        || fatal "no node #$1 in the subscription"
    _id="$(printf '%s' "$_row" | cut -f1)"
    _ok="$(printf '%s' "$_row" | cut -f2)"
    _reason="$(printf '%s' "$_row" | cut -f3)"
    _kind="$(printf '%s' "$_row" | cut -f4)"
    _link="$(printf '%s' "$_row" | cut -f5-)"
    [ "$_ok" = "1" ] || fatal "node #$1 is unsupported${_reason:+ ($_reason)}"
    if [ "$_kind" = "pool" ]; then
        # JSON balancer/pool profile: extract its raw JSON and import via the
        # -confdir balancer path (builds + validates + applies, state-safe).
        _pf="$(mktemp "$ETC_DIR/.subpool.XXXXXX")" || fatal "could not create temp file"
        # shellcheck disable=SC2064
        trap "rm -f '$_pf'" EXIT INT TERM HUP
        py "$MKSUB" profile --file "$SUB_CATALOG" --id "$_id" > "$_pf" 2>/dev/null \
            || { rm -f "$_pf"; trap - EXIT INT TERM HUP; fatal "could not extract the selected profile"; }
        _FROM_SUB=1 cmd_import_json "$_pf"
        rm -f "$_pf"; trap - EXIT INT TERM HUP
    else
        # single share link: reuse the hardened single-link path. Verify it still
        # resolves to the catalog id first (guards against transport mangling).
        if ! py "$MKSUB" find --file "$SUB_CATALOG" --id "$_id" >/dev/null 2>&1; then
            fatal "selected node could not be confirmed in the catalog; refresh and retry"
        fi
        _FROM_SUB=1 cmd_import "$_link"
    fi
    # record the selection only after a successful import; check the write
    mkdir -p "$SUB_DIR" || fatal "could not record selection"
    printf '%s' "$_id" > "$SUB_SELECTED" || fatal "could not record selection marker"
    chmod 600 "$SUB_SELECTED" 2>/dev/null || true
    c_grn "Selected subscription node #$1 (id $_id)."
}

# Refresh the catalog. The active tunnel is NEVER changed automatically: a node's
# id is the hash of its canonical config, so if the selected id is still present
# the config is identical (only the label could differ). If it is gone, the
# provider changed or removed that node -- we keep the working tunnel and ask the
# user to re-select, rather than silently activating a different config.
sub_refresh() {
    sub_fetch || { err "refresh failed; keeping the current catalog and tunnel"; return 1; }
    c_grn "Catalog refreshed."
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    [ -n "$_sel" ] || { sub_list; return 0; }
    if py "$MKSUB" find --file "$SUB_CATALOG" --id "$_sel" >/dev/null 2>&1; then
        info "selected node (id $_sel) is unchanged."
    else
        c_ylw "Selected node (id $_sel) changed or was removed by the provider."
        c_ylw "The active tunnel is unchanged. Re-open the subscription menu and re-select to apply."
    fi
}

sub_remove() {
    rm -f "$SUB_URL_FILE" "$SUB_CATALOG" "$SUB_SELECTED"
    c_ylw "Subscription removed (HWID kept). The active tunnel is unchanged."
    info "To also stop proxying, use the menu (Stop) or import a different link."
}

sub_status() {
    if [ ! -s "$SUB_URL_FILE" ]; then echo "subscription: (none)"; return; fi
    echo "subscription: configured"
    if [ -f "$SUB_CATALOG" ]; then
        py - "$SUB_CATALOG" <<'PYEOF' 2>/dev/null || true
import json,sys
c=json.load(open(sys.argv[1]))
m=c.get("meta",{})
print("nodes:        %s (%s supported)" % (m.get("count","?"), m.get("supported","?")))
if "interval_hours" in m: print("provider hint: refresh every %sh" % m["interval_hours"])
if "userinfo" in m: print("userinfo:     %s" % m["userinfo"])
PYEOF
    else
        echo "nodes:        (not fetched yet; refresh from the subscription menu)"
    fi
    _sel="$(cat "$SUB_SELECTED" 2>/dev/null || true)"
    echo "selected:     ${_sel:-(none)}"
    echo "hwid:         $([ -s "$SUB_HWID_FILE" ] && echo set || echo unset)"
}


cmd_uninstall() {
    need_root
    systemctl disable --now "$SERVICE_NAME" 2>/dev/null || true
    systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
    rm -f "$SERVICE_FILE" "$PLUGIN_SERVICE_FILE" "$ONBOOT_DST"
    remove_proxy_link
    systemctl daemon-reload 2>/dev/null || true
    c_ylw "Removed service + boot hook. Data kept at $ROOT (delete it manually to purge keys/config)."
    c_ylw "Don't forget to delete the WireGuard VPN Client in the UniFi UI."
}

usage() {
    cat <<EOF
proxy - multi-core proxy client (xray-core + sing-box) for UniFi gateways

Run 'proxy' with no arguments for the interactive management menu — it is the
full interface: import links, subscriptions, WireGuard config, keys, port/MTU/DNS,
ping test, autostart, updates, and uninstall.

Direct commands (quick ops / scripting):
  proxy start        Start the service
  proxy stop         Stop the service
  proxy restart      Restart the service
  proxy status       Show engine / server / listener status
  proxy logs [args]  Tail service logs (passes args to journalctl)
  proxy help         This help

Everything else lives in the menu (run 'proxy').
Data lives in $ROOT and survives reboots/firmware upgrades via unifi-common.
EOF
}

# --------------------------------------------------------------------------
# Dispatch
# --------------------------------------------------------------------------
load_settings
cmd="${1:-}"; [ $# -ge 1 ] && shift || true
case "$cmd" in
    # interactive menu (default) — the menu is the full interface for everything:
    # import, subscriptions, keys, port/MTU/DNS, ping, autostart, update, uninstall.
    "")           need_root; cmd_menu ;;
    # kept direct commands (quick ops / scripting)
    start)        need_root; cmd_start ;;
    stop)         need_root; cmd_stop ;;
    restart)      need_root; cmd_restart ;;
    status)       cmd_status ;;
    logs)         cmd_logs logs "$@" ;;
    -h|--help|help) usage ;;
    # internal hooks (used only by install.sh and the boot hook, not user-facing)
    install-binary)  need_root; cmd_install_binary ;;
    install-service) need_root; install_service ;;
    *) err "unknown command: $cmd"; echo; usage; exit 1 ;;
esac
