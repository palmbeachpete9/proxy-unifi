# D20: only create/remove /usr/bin/proxy if it is absent or already OUR symlink,
# never clobbering an unrelated file someone else owns.
PROXY_LINK="/usr/bin/proxy"
proxy_link_is_ours() {
    [ -L "$PROXY_LINK" ] || return 1
    case "$(readlink "$PROXY_LINK" 2>/dev/null)" in
        "$BIN_DIR/proxy-unifi") return 0 ;;
        *) return 1 ;;
    esac
}
install_proxy_link() {
    if [ -e "$PROXY_LINK" ] && [ ! -L "$PROXY_LINK" ]; then
        c_ylw "warning: $PROXY_LINK exists and is not a symlink; leaving it untouched."
        return 0
    fi
    if [ -L "$PROXY_LINK" ] && ! proxy_link_is_ours; then
        c_ylw "warning: $PROXY_LINK points elsewhere; leaving it untouched."
        return 0
    fi
    ln -sf "$BIN_DIR/proxy-unifi" "$PROXY_LINK"
}
remove_proxy_link() {
    # remove only if it is absent-as-file or our own symlink
    if [ -L "$PROXY_LINK" ] && ! proxy_link_is_ours; then
        c_ylw "note: $PROXY_LINK points elsewhere; not removing it."
        return 0
    fi
    if [ -L "$PROXY_LINK" ]; then rm -f "$PROXY_LINK"; fi
}

py() {
    # Force UTF-8 I/O regardless of the gateway's locale (UniFi OS often runs
    # with LANG unset / C locale). Without this, printing multi-byte text -- e.g.
    # Cyrillic / CJK subscription labels -- can get mangled.
    PYTHONUTF8=1 PYTHONIOENCODING=utf-8 _py_run "$@"
}
_py_run() {
    if have python3; then python3 "$@";
    elif have python; then python "$@";
    else fatal "python3 is required but was not found on this gateway.";
    fi
}

RUN_DIR=""
LOCK_HELD=0
LOCK_OWNER=""
TXN_DIR=""
BG_PID=""
EDIT_DRAFT=""
UPDATE_BACKUP=""
UPDATE_WAS_ACTIVE=0
GEO_BACKUP=""
GEO_WAS_ACTIVE=0

ensure_run_dir() {
    [ -n "$RUN_DIR" ] && [ -d "$RUN_DIR" ] && return 0
    mkdir -p "$ROOT"
    RUN_DIR="$(mktemp -d "$ROOT/.run.XXXXXX")" || fatal "could not create private run directory"
    chmod 700 "$RUN_DIR"
}

acquire_lock() {
    [ "$LOCK_HELD" = 1 ] && return 0
    # POSIX shells keep $$ unchanged in (...) subshells. Ask a short-lived child
    # for its PPID so a menu action records its real process id in the lock.
    LOCK_OWNER="$(sh -c 'printf "%s\n" "$PPID"' 2>/dev/null || true)"
    case "$LOCK_OWNER" in ""|*[!0-9]*) LOCK_OWNER="$$" ;; esac
    mkdir -p "$ROOT" || fatal "could not create $ROOT"
    _tries=0
    _uninitialized=0
    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        _owner="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
        case "$_owner" in ""|*[!0-9]*) _owner="" ;; esac
        if [ -z "$_owner" ]; then
            # Another process may be between mkdir and writing pid. Give it a
            # short initialization window before treating an empty lock as stale.
            _uninitialized=$((_uninitialized + 1))
            if [ "$_uninitialized" -lt 10 ]; then
                sleep 0.2 2>/dev/null || sleep 1
                continue
            fi
            rm -rf "$LOCK_DIR" 2>/dev/null || true
            _uninitialized=0
            continue
        fi
        _uninitialized=0
        if ! kill -0 "$_owner" 2>/dev/null; then
            rm -rf "$LOCK_DIR" 2>/dev/null || true
            continue
        fi
        _tries=$((_tries + 1))
        [ "$_tries" -lt 150 ] || fatal "another proxy-unifi operation is still running (pid $_owner)"
        sleep 0.2 2>/dev/null || sleep 1
    done
    printf '%s\n' "$LOCK_OWNER" > "$LOCK_DIR/pid" \
        || { rm -rf "$LOCK_DIR" 2>/dev/null || true; fatal "could not initialize operation lock"; }
    LOCK_HELD=1
}

release_lock() {
    [ "$LOCK_HELD" = 1 ] || return 0
    _owner="$(cat "$LOCK_DIR/pid" 2>/dev/null || true)"
    if [ "$_owner" = "$LOCK_OWNER" ]; then rm -rf "$LOCK_DIR" 2>/dev/null || true; fi
    LOCK_HELD=0
    LOCK_OWNER=""
}

fsync_dir() {
    py - "$1" <<'PYEOF' 2>/dev/null
import os, sys
flags = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0)
fd = os.open(sys.argv[1], flags)
try:
    os.fsync(fd)
finally:
    os.close(fd)
PYEOF
}

fsync_tree() {
    py - "$1" <<'PYEOF' 2>/dev/null
import os, stat, sys
root = sys.argv[1]
directories = []
for current, dirs, files in os.walk(root):
    directories.append(current)
    for name in files:
        path = os.path.join(current, name)
        mode = os.lstat(path).st_mode
        if not stat.S_ISREG(mode):
            continue
        fd = os.open(path, os.O_RDONLY)
        try:
            os.fsync(fd)
        finally:
            os.close(fd)
flags = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0)
for path in reversed(directories):
    fd = os.open(path, flags)
    try:
        os.fsync(fd)
    finally:
        os.close(fd)
PYEOF
}

# Restore the ETC snapshot without consuming it. The transaction marker is
# cleared only after this copy-and-swap is durable, so recovery remains
# repeatable even if power is lost during an earlier recovery attempt.
restore_transaction_files() {
    _rt_state="$1"
    _rt_candidate="$_rt_state/restore-candidate"
    _rt_failed="$_rt_state/failed-current"
    rm -rf "$_rt_candidate" "$_rt_failed" || return 1
    if [ -f "$_rt_state/had-etc" ]; then
        [ -d "$_rt_state/etc" ] || return 1
        cp -Rp "$_rt_state/etc" "$_rt_candidate" || { rm -rf "$_rt_candidate"; return 1; }
        fsync_tree "$_rt_candidate" || { rm -rf "$_rt_candidate"; return 1; }
        if [ -e "$ETC_DIR" ] || [ -L "$ETC_DIR" ]; then
            mv "$ETC_DIR" "$_rt_failed" || { rm -rf "$_rt_candidate"; return 1; }
        fi
        if ! mv "$_rt_candidate" "$ETC_DIR"; then
            if [ -e "$_rt_failed" ]; then mv "$_rt_failed" "$ETC_DIR" 2>/dev/null || true; fi
            rm -rf "$_rt_candidate"
            return 1
        fi
        fsync_dir "$ROOT" || return 1
        rm -rf "$_rt_failed" || return 1
    else
        rm -rf "$ETC_DIR" || return 1
        fsync_dir "$ROOT" || return 1
    fi
}

restore_runtime_state() {
    _state="$1"
    if [ ! -f "$_state/runtime-state" ]; then
        [ -f "$SERVICE_FILE" ] && { ( write_service ) 2>/dev/null || true; systemctl restart "$SERVICE_NAME" 2>/dev/null || true; }
        return 0
    fi
    if [ -f "$SERVICE_FILE" ]; then
        ( write_service ) 2>/dev/null || true
        if [ -f "$_state/service-enabled" ]; then
            systemctl enable "$SERVICE_NAME" >/dev/null 2>&1 || true
        else
            systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || true
        fi
        if [ -f "$_state/service-active" ]; then
            systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else
            systemctl stop "$SERVICE_NAME" 2>/dev/null || true
        fi
    fi
    if [ -s "$SUB_URL_FILE" ]; then
        ( load_settings; write_refresh_timer ) 2>/dev/null || true
    fi
    if [ -f "$_state/timer-enabled" ]; then
        systemctl enable "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1 || true
    else
        systemctl disable "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1 || true
    fi
    if [ -f "$_state/timer-active" ]; then
        systemctl start "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1 || true
    else
        systemctl stop "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1 || true
    fi
}

recover_transaction() {
    [ -s "$TXN_MARKER" ] || return 0
    _recover="$(cat "$TXN_MARKER" 2>/dev/null || true)"
    case "$(basename "$_recover" 2>/dev/null)" in txn.*) : ;; *) fatal "transaction marker is malformed" ;; esac
    [ "$(dirname "$_recover" 2>/dev/null)" = "$TXN_ROOT" ] \
        || fatal "transaction marker escapes the transaction directory"
    [ -d "$_recover" ] || fatal "transaction recovery directory is missing"
    c_ylw "Recovering an interrupted proxy-unifi state transaction."
    restore_transaction_files "$_recover" \
        || fatal "could not recover interrupted state transaction"
    restore_runtime_state "$_recover"
    rm -f "$TXN_MARKER" || fatal "could not clear recovered transaction marker"
    fsync_dir "$TXN_ROOT" || fatal "could not persist transaction recovery"
    rm -rf "$_recover"
}

txn_begin() {
    [ -z "$TXN_DIR" ] || return 0
    mkdir -p "$TXN_ROOT"
    chmod 700 "$TXN_ROOT" || fatal "could not secure transaction directory"
    TXN_DIR="$(mktemp -d "$TXN_ROOT/txn.XXXXXX")" || fatal "could not create state transaction"
    chmod 700 "$TXN_DIR"
    if [ -d "$ETC_DIR" ]; then
        : > "$TXN_DIR/had-etc"
        cp -Rp "$ETC_DIR" "$TXN_DIR/etc" || fatal "could not snapshot current state"
    fi
    if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then : > "$TXN_DIR/service-active"; fi
    if systemctl is-enabled --quiet "$SERVICE_NAME" 2>/dev/null; then : > "$TXN_DIR/service-enabled"; fi
    if systemctl is-active --quiet "${SERVICE_NAME}-refresh.timer" 2>/dev/null; then
        : > "$TXN_DIR/timer-active"
    fi
    if systemctl is-enabled --quiet "${SERVICE_NAME}-refresh.timer" 2>/dev/null; then
        : > "$TXN_DIR/timer-enabled"
    fi
    : > "$TXN_DIR/runtime-state"
    fsync_tree "$TXN_DIR" || fatal "could not persist state transaction snapshot"
    printf '%s\n' "$TXN_DIR" | atomic_write "$TXN_MARKER" 600 \
        || fatal "could not activate state transaction"
}

txn_commit() {
    [ -n "$TXN_DIR" ] || return 0
    rm -f "$TXN_MARKER" || fatal "could not clear committed transaction marker"
    fsync_dir "$TXN_ROOT" || fatal "could not persist transaction commit"
    rm -rf "$TXN_DIR"
    TXN_DIR=""
}

txn_rollback() {
    [ -n "$TXN_DIR" ] || return 0
    _rollback="$TXN_DIR"
    restore_transaction_files "$_rollback" || return 1
    restore_runtime_state "$_rollback"
    rm -f "$TXN_MARKER" || return 1
    fsync_dir "$TXN_ROOT" || return 1
    rm -rf "$_rollback"
    TXN_DIR=""
}

on_exit() {
    _rc="$1"
    trap - EXIT INT TERM HUP
    [ -z "$BG_PID" ] || { kill "$BG_PID" 2>/dev/null || true; wait "$BG_PID" 2>/dev/null || true; }
    [ -z "$EDIT_DRAFT" ] || rm -f "$EDIT_DRAFT" 2>/dev/null || true
    if [ -n "$UPDATE_BACKUP" ]; then
        _restore_update_backup "$UPDATE_BACKUP" || err "core update rollback was incomplete"
        ( write_service ) 2>/dev/null || true
        if [ "$UPDATE_WAS_ACTIVE" = 1 ]; then systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else systemctl stop "$SERVICE_NAME" 2>/dev/null || true; fi
        UPDATE_BACKUP=""
    fi
    if [ -n "$GEO_BACKUP" ]; then
        _restore_geo_backup "$GEO_BACKUP" || err "geo update rollback was incomplete"
        if [ "$GEO_WAS_ACTIVE" = 1 ]; then systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else systemctl stop "$SERVICE_NAME" 2>/dev/null || true; fi
        GEO_BACKUP=""
    fi
    if [ -n "$TXN_DIR" ] && ! txn_rollback; then
        err "state rollback was incomplete; boot recovery will retry it"
        _rc=1
    fi
    [ -z "$RUN_DIR" ] || rm -rf "$RUN_DIR"
    release_lock
    exit "$_rc"
}
trap 'on_exit $?' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM
trap 'exit 129' HUP

locked_call() {
    # Interactive prompts happen before this wrapper is entered. This prevents
    # an idle terminal from blocking the scheduled subscription refresh timer.
    # dash does not inherit EXIT traps into (...) action subshells, so install
    # the cleanup contract again here before any mutating function can fatal().
    trap 'on_exit $?' EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM
    trap 'exit 129' HUP
    set -e
    acquire_lock
    recover_transaction
    "$@"
    _locked_rc=$?
    if [ -n "$TXN_DIR" ]; then
        txn_rollback
        _locked_rc=1
    fi
    release_lock
    return "$_locked_rc"
}

# Generate a WireGuard keypair -> prints "PRIVATE PUBLIC" on one line.
gen_keypair() {
    if have wg; then
        _priv="$(wg genkey)"
        _pub="$(printf '%s' "$_priv" | wg pubkey)"
    elif have openssl; then
        ensure_run_dir
        _tmp="$RUN_DIR/x25519.pem"
        openssl genpkey -algorithm X25519 -out "$_tmp" 2>/dev/null \
            || fatal "openssl could not generate an X25519 key"
        _priv="$(openssl pkey -in "$_tmp" -outform DER 2>/dev/null | tail -c 32 | base64)"
        _pub="$(openssl pkey -in "$_tmp" -pubout -outform DER 2>/dev/null | tail -c 32 | base64)"
        rm -f "$_tmp"
    else
        fatal "need either 'wg' or 'openssl' to generate WireGuard keys"
    fi
    printf '%s %s\n' "$_priv" "$_pub"
}

ensure_keys() {
    mkdir -p "$WG_DIR"
    chmod 700 "$WG_DIR"
    # migrate legacy key names (xray-only era) -> engine-neutral names, so an
    # upgrade reuses the existing keypair instead of regenerating (which would
    # break the already-applied UniFi WireGuard VPN Client).
    if [ -s "$WG_DIR/xray_private.key" ] && [ ! -s "$WG_DIR/wg_private.key" ]; then
        rm -f "$WG_DIR/wg_private.key"
        mv "$WG_DIR/xray_private.key" "$WG_DIR/wg_private.key"
    fi
    if [ -s "$WG_DIR/xray_public.key" ] && [ ! -s "$WG_DIR/wg_public.key" ]; then
        rm -f "$WG_DIR/wg_public.key"
        mv "$WG_DIR/xray_public.key" "$WG_DIR/wg_public.key"
    fi
    # Each keypair is repaired independently so a missing/lost file never destroys
    # a still-valid pair. If a private key exists but its public is missing, derive
    # the public from the private (when 'wg' is available) instead of regenerating.
    _ensure_pair wg
    _ensure_pair unifi
    chmod 600 "$WG_DIR"/*.key 2>/dev/null || true
}

# _ensure_pair <prefix>: guarantee $WG_DIR/<prefix>_private.key + _public.key exist
# and are CONSISTENT (public is actually derived from private), repairing only the
# public half when possible and never rotating a valid private key needlessly.
_ensure_pair() {
    _pp="$WG_DIR/$1_private.key"; _pub="$WG_DIR/$1_public.key"
    if [ -s "$_pp" ]; then
        _derived=""
        if have wg; then
            _derived="$(wg pubkey < "$_pp" 2>/dev/null || true)"
        elif have openssl; then
            ensure_run_dir
            _der="$RUN_DIR/$1-private.der"
            py - "$_pp" "$_der" <<'PYEOF' 2>/dev/null || true
import base64,sys
raw=base64.b64decode(open(sys.argv[1],"rb").read().strip(),validate=True)
if len(raw)!=32: raise SystemExit(1)
open(sys.argv[2],"wb").write(bytes.fromhex("302e020100300506032b656e04220420")+raw)
PYEOF
            if [ -s "$_der" ]; then
                _derived="$(openssl pkey -inform DER -in "$_der" -pubout -outform DER 2>/dev/null | tail -c 32 | base64 || true)"
            fi
        fi
        if [ -n "$_derived" ]; then
            if [ ! -s "$_pub" ] || [ "$_derived" != "$(cat "$_pub" 2>/dev/null)" ]; then
                # repair only the public half to match the (kept) private key
                printf '%s' "$_derived" | atomic_write "$_pub" 600 || fatal "could not repair public key"
            fi
            return 0
        fi
        fatal "existing $1 WireGuard private key is invalid; refusing automatic rotation"
    fi
    # otherwise (re)generate the whole pair
    info "generating WireGuard keypair: $1 ..."
    _kp="$(gen_keypair)"
    printf '%s' "${_kp% *}" | atomic_write "$_pp" 600 || fatal "could not store private key"
    printf '%s' "${_kp#* }" | atomic_write "$_pub" 600 || fatal "could not store public key"
}

arch_slug() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64-v8a" ;;
        x86_64|amd64)  echo "64" ;;
        armv7l|armhf)  echo "arm32-v7a" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# --------------------------------------------------------------------------
# Share-link engine selection (xray vs sing-box; AWG uses saved profiles)
# --------------------------------------------------------------------------
# Which engine handles a link file: "xray", "singbox", or "" (unsupported).
engine_for_link_file() {
    _ef_file="$1"
    [ -s "$_ef_file" ] || { echo ""; return; }
    _ef_link="$(cat "$_ef_file")"
    case "$_ef_link" in
        vless://*|vmess://*|trojan://*) echo xray; return ;;
        hysteria2://*|hy2://*|tuic://*) echo singbox; return ;;
        ss://*)
            _pn="$(py "$MKXRAY" --link-file "$_ef_file" --print-plugin 2>/dev/null)"
            if [ -z "$_pn" ]; then echo xray; return; fi   # plain SS -> xray
            case "$_pn" in
                obfs-local|simple-obfs|v2ray-plugin) echo singbox ;;  # sing-box runs these in-process
                *) echo "" ;;                                        # other SIP003 plugins: unsupported
            esac
            return ;;
    esac
    echo ""
}

current_engine() {
    # Trust the engine marker only if it is one of the known values; otherwise
    # infer from on-disk state (an empty/corrupt marker must not default to the
    # wrong core, e.g. running a hysteria2 link under xray).
    _ce="$(cat "$ENGINE_FILE" 2>/dev/null || true)"
    case "$_ce" in
        xray|singbox|xraypool|awg) echo "$_ce"; return ;;
    esac
    if [ -s "$AWG_SELECTED" ] && awg_selected_profile >/dev/null 2>&1; then echo awg; return; fi
    # a pool dir present means we're in pool mode
    if [ -f "$POOL_DIR/99-overlay.json" ]; then echo xraypool; return; fi
    if [ -f "$OUTBOUND_LINK" ]; then
        _ce="$(engine_for_link_file "$OUTBOUND_LINK")"
        [ -n "$_ce" ] && { echo "$_ce"; return; }
    fi
    echo xray
}

# map our (xray-style) loglevel to sing-box's vocabulary
sb_loglevel() {
    case "$LOGLEVEL" in
        warning) echo warn ;;
        none)    echo fatal ;;
        debug|info|error) echo "$LOGLEVEL" ;;
        *) echo warn ;;
    esac
}

sb_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64|amd64)  echo "amd64" ;;
        armv7l|armhf)  echo "armv7" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# Download <url> to <dest> using whichever of curl/wget exists. Returns nonzero on
# failure (and removes a partial file). One place, so tag-resolution and the
# tarball download use the same available tool.
download_to() {
    _d_url="$1"; _d_dst="$2"; _d_max="${3:-419430400}"
    if have curl; then
        ( ulimit -f $(((_d_max + 511) / 512)) 2>/dev/null || exit 1
          curl -fsSL --connect-timeout 30 --max-time 600 --retry 6 --retry-delay 3 \
              --max-filesize "$_d_max" "$_d_url" -o "$_d_dst" ) \
            || { rm -f "$_d_dst"; return 1; }
    elif have wget; then
        ( ulimit -f $(((_d_max + 511) / 512)) 2>/dev/null || exit 1
          wget -q --timeout=45 --tries=6 -O "$_d_dst" "$_d_url" ) \
            || { rm -f "$_d_dst"; return 1; }
    else
        return 1
    fi
    _d_size="$(wc -c < "$_d_dst" | tr -d ' ')"
    case "$_d_size" in ""|*[!0-9]*) rm -f "$_d_dst"; return 1 ;; esac
    [ "$_d_size" -le "$_d_max" ] || { rm -f "$_d_dst"; return 1; }
}

DOWNLOAD_URL_USED=""
download_any_to() {
    _da_dst="$1"; _da_max="$2"; shift 2
    DOWNLOAD_URL_USED=""
    for _da_url in "$@"; do
        [ -n "$_da_url" ] || continue
        if download_to "$_da_url" "$_da_dst" "$_da_max"; then
            DOWNLOAD_URL_USED="$_da_url"
            return 0
        fi
    done
    return 1
}

# Resolve the latest tag from a .../releases/latest redirect with the available tool.
resolve_latest_tag() {
    if have curl; then
        curl -fsSLI --connect-timeout 30 --max-time 120 --retry 5 --retry-delay 3 "$1/latest" 2>/dev/null
    elif have wget; then
        wget -qS --timeout=45 --tries=5 --max-redirect=0 "$1/latest" -O /dev/null 2>&1
    fi | awk -F'/tag/' '
        tolower($0) ~ /location:/ {
            value=$2; sub(/[[:space:]\r].*$/, "", value); tag=value
        }
        END { if (tag != "") print tag }'
}

# compute the SHA-256 of a file with whatever tool exists; echoes the hex digest
sha256_of() {
    if have sha256sum; then sha256sum "$1" | awk '{print $1}'
    elif have shasum;   then shasum -a 256 "$1" | awk '{print $1}'
    else py - "$1" <<'PYEOF' 2>/dev/null
import hashlib, sys
digest = hashlib.sha256()
with open(sys.argv[1], "rb") as source:
    for chunk in iter(lambda: source.read(1024 * 1024), b""):
        digest.update(chunk)
print(digest.hexdigest())
PYEOF
    fi
}

# Verify $1 (a downloaded file) against the expected sha256 in $2 (a string).
# Integrity check only (the digest is published next to the file by upstream).
# Returns 0 on match, 1 on mismatch, 2 if no expected hash / cannot hash.
verify_sha256() {
    [ -n "${2:-}" ] || return 2
    _got="$(sha256_of "$1")"
    [ -n "$_got" ] || return 2
    [ "$_got" = "$2" ] && return 0
    err "checksum mismatch for $(basename "$1") (got $_got, expected $2)"
    return 1
}

github_asset_digest() {
    _gh_repo="$1"; _gh_tag="$2"; _gh_name="$3"
    ensure_run_dir
    _gh_meta="$RUN_DIR/release-$(printf '%s' "$_gh_repo-$_gh_tag" | tr '/:' '__').json"
    download_to "https://api.github.com/repos/${_gh_repo}/releases/tags/${_gh_tag}" "$_gh_meta" 10485760 || return 1
    py - "$_gh_meta" "$_gh_name" <<'PYEOF'
import json,sys
data=json.load(open(sys.argv[1],encoding="utf-8"))
for asset in data.get("assets",[]):
    if asset.get("name")==sys.argv[2]:
        digest=asset.get("digest","")
        if digest.startswith("sha256:"):
            print(digest.split(":",1)[1]); raise SystemExit(0)
raise SystemExit(1)
PYEOF
}

cmd_install_singbox() {
    mkdir -p "$BIN_DIR"
    { have curl || have wget; } || { err "need curl or wget to download sing-box"; return 1; }
    _sa="$(sb_arch)"
    _tag="$(resolve_latest_tag "$SINGBOX_RELEASES")"
    [ -n "$_tag" ] || { err "could not resolve sing-box latest version"; return 1; }
    _ver="${_tag#v}"
    _asset="sing-box-${_ver}-linux-${_sa}.tar.gz"
    _url="$SINGBOX_RELEASES/download/${_tag}/${_asset}"
    ensure_run_dir
    _tmp="$RUN_DIR/singbox"; mkdir -p "$_tmp"
    info "downloading sing-box ${_tag} (${_sa}) ..."
    download_to "$_url" "$_tmp/sb.tgz" 262144000 || { rm -rf "$_tmp"; err "sing-box download failed"; return 1; }
    _want="$(github_asset_digest SagerNet/sing-box "$_tag" "$_asset" 2>/dev/null)" \
        || { rm -rf "$_tmp"; err "could not obtain sing-box's GitHub asset digest"; return 1; }
    verify_sha256 "$_tmp/sb.tgz" "$_want" \
        || { rm -rf "$_tmp"; err "sing-box checksum verification failed"; return 1; }
    py - "$_tmp/sb.tgz" "$_tmp" <<'PYEOF' || { rm -rf "$_tmp"; err "could not safely extract sing-box"; return 1; }
import os,sys,tarfile
src,dest=sys.argv[1],os.path.realpath(sys.argv[2]); total=0; limit=250*1024*1024
with tarfile.open(src,"r:gz") as archive:
    members=archive.getmembers()
    for member in members:
        target=os.path.realpath(os.path.join(dest,member.name))
        if target!=dest and not target.startswith(dest+os.sep): raise SystemExit("unsafe archive path")
        if member.issym() or member.islnk() or member.isdev() or member.isfifo(): raise SystemExit("unsafe archive member")
        total += max(0,member.size)
        if total>limit: raise SystemExit("archive is too large")
    archive.extractall(dest,members=members)
PYEOF
    _b="$(find "$_tmp" -name sing-box -type f -print -quit)"
    [ -n "$_b" ] || { rm -rf "$_tmp"; err "sing-box binary not found in archive"; return 1; }
    chmod 0755 "$_b"
    # verify the staged binary runs
    "$_b" version >/dev/null 2>&1 || { rm -rf "$_tmp"; err "downloaded sing-box binary did not run"; return 1; }
    # D15: if sing-box is the active engine and we have a config, validate it
    # against the NEW binary before switching; keep a backup for rollback.
    if [ -x "$SBIN" ] && [ "$(current_engine)" = "singbox" ] && [ -f "$CONFIG" ]; then
        prepare_service_permissions
        chown root:"$SERVICE_GROUP" "$RUN_DIR" "$_tmp" 2>/dev/null || true
        chmod 750 "$RUN_DIR" "$_tmp" 2>/dev/null || true
        validate_as_service "$_b" check -c "$CONFIG" >/dev/null 2>&1 \
            || { rm -rf "$_tmp"; err "the new sing-box rejects your current config; keeping the old version"; return 1; }
    fi
    if [ -x "$SBIN" ]; then
        cp -p "$SBIN" "$SBIN.bak.new" || { rm -rf "$_tmp"; err "could not back up sing-box"; return 1; }
        mv -f "$SBIN.bak.new" "$SBIN.bak"
    fi
    install -m 0755 "$_b" "$SBIN.new" || { rm -rf "$_tmp"; rm -f "$SBIN.new"; err "could not install sing-box binary"; return 1; }
    mv -f "$SBIN.new" "$SBIN" || { rm -rf "$_tmp"; err "could not activate sing-box binary"; return 1; }
    if ! "$SBIN" version >/dev/null 2>&1; then
        [ -f "$SBIN.bak" ] && mv -f "$SBIN.bak" "$SBIN"
        rm -rf "$_tmp"; err "new sing-box failed to run; rolled back to the previous version"; return 1
    fi
    rm -rf "$_tmp"
    c_grn "sing-box installed: $(core_version "$SBIN")"
}

ensure_singbox() {
    [ -x "$SBIN" ] || cmd_install_singbox || true
    [ -x "$SBIN" ] || fatal "sing-box is required for this link but could not be installed"
