cmd_menu() {
    # Interactive loop: turn off errexit and run each action in a subshell so a
    # failing action (including any fatal/exit) reports its error and returns to
    # the menu instead of killing the whole program.
    need_root
    # Repair an interrupted transaction before displaying any persisted state,
    # but release the lock before waiting for the user's first selection.
    ( locked_call true ) || fatal "could not recover interrupted state"
    set +e
    while true; do
        clear 2>/dev/null || true
        print_menu
        printf '\nPlease enter your selection [0-21]: '
        read -r sel || exit 0
        echo
        case "$sel" in
            0)  exit 0 ;;
            1)  ( printf 'Paste proxy link (vless/vmess/trojan/ss/hysteria2/tuic): '; read -r _l || true
                  if [ -n "${_l:-}" ]; then locked_call cmd_import "$_l"; else c_ylw "No link entered."; fi ) ;;
            2)  ( menu_sub ) ;;
            3)  ( menu_awg ) ;;
            4)  ( menu_import_json ) ;;
            5)  ( cmd_config ) ;;
            6)  ( cmd_wg_config ) ;;
            7)  ( printf 'Regenerate keys? This breaks the current UniFi VPN Client until you re-paste the new config. [y/N]: '
                  read -r _c || true
                  if [ "${_c:-}" = "y" ]; then locked_call cmd_regen_keys; else c_ylw "Cancelled."; fi ) ;;
            8)  ( menu_wg_settings ) ;;
            9)  ( cmd_ping ) ;;
            10) ( menu_set_ping ) ;;
            11) ( locked_call menu_start ) ;;
            12) ( locked_call menu_stop ) ;;
            13) ( locked_call menu_restart ) ;;
            14) ( cmd_status ) ;;
            15) ( printf 'Lines to show [100]: '; read -r _n || true
                  case "${_n:-}" in ""|*[!0-9]*) _n=100 ;; esac
                  cmd_logs logs -n "$_n" --no-pager ) ;;
            16) ( locked_call menu_enable ) ;;
            17) ( locked_call menu_disable ) ;;
            18) ( locked_call cmd_update ) ;;
            19) ( locked_call cmd_geo_update ) ;;
            20) ( if [ -x "$XRAY" ]; then core_version "$XRAY"; else c_ylw "xray-core: not installed"; fi
                  if [ -x "$SBIN" ]; then core_version "$SBIN"; else c_ylw "sing-box: not installed"; fi
                  if [ -x "$ABIN" ]; then core_version "$ABIN"; else c_ylw "AmneziaWG core: not installed"; fi
                  echo "proxy-unifi CLI 1.0.0" ) ;;
            21) printf 'Really uninstall the service + boot hook? [y/N]: '; read -r _c || true
                if [ "${_c:-}" = "y" ]; then ( locked_call cmd_uninstall ); pause; exit 0; else c_ylw "Cancelled."; fi ;;
            *)  c_red "Invalid selection." ;;
        esac
        pause
    done
}

