awg_commit_new() {
    _awg_name="$1"; _awg_draft="$2"
    _awg_name="$(py "$MKAWG" name --value "$_awg_name")" \
        || fatal "invalid display name"
    py "$MKAWG" validate --file "$_awg_draft" >/dev/null \
        || fatal "AmneziaWG profile validation failed"
    awg_secure_dirs
    _awg_id="$(py -c 'import uuid; print(uuid.uuid4())')"
    [ -n "$_awg_id" ] || fatal "could not generate profile id"
    _awg_conf="$AWG_PROFILES_DIR/${_awg_id}.conf"
    _awg_name_file="$AWG_PROFILES_DIR/${_awg_id}.name"
    txn_begin
    atomic_write "$_awg_conf" 600 < "$_awg_draft" || fatal "could not store AmneziaWG profile"
    printf '%s' "$_awg_name" | atomic_write "$_awg_name_file" 600 \
        || fatal "could not store AmneziaWG display name"
    txn_commit
    awg_resolve "$_awg_id" allow
    c_grn "Saved AmneziaWG profile: $AWG_PICK_NAME"
}

awg_select() {
    awg_resolve "$1"
    load_settings
    txn_begin
    _build_awg_profile "$AWG_PICK_PATH"
    printf '%s' "$AWG_PICK_ID" | atomic_write "$AWG_SELECTED" 600 \
        || fatal "could not record selected AmneziaWG profile"
    # AWG activation supersedes every other active source, but retains saved
    # subscriptions and AWG profiles so the user can switch back later.
    rm -f "$OUTBOUND_LINK" "$SUB_SELECTED" "$SUB_SELECTED_META" 2>/dev/null || true
    rm -rf "$POOL_DIR" "$POOL_SRC" 2>/dev/null || true
    save_settings
    restart_service || fatal "profile was valid, but the service failed its startup health check"
    txn_commit
    c_grn "Selected and activated AmneziaWG profile: $AWG_PICK_NAME"
}

awg_commit_edit() {
    _awg_id="$1"; _awg_draft="$2"; _awg_original_hash="$3"
    case "$_awg_id" in ????????-????-????-????-????????????) : ;; *) fatal "invalid profile id" ;; esac
    case "$_awg_id" in *[!0-9a-f-]*) fatal "invalid profile id" ;; esac
    _awg_conf="$AWG_PROFILES_DIR/${_awg_id}.conf"
    if [ ! -f "$_awg_conf" ] || [ -L "$_awg_conf" ]; then
        fatal "profile no longer exists"
    fi
    [ "$(sha256_of "$_awg_conf")" = "$_awg_original_hash" ] \
        || fatal "profile changed while the editor was open; refusing to overwrite it"
    py "$MKAWG" validate --file "$_awg_draft" >/dev/null \
        || fatal "AmneziaWG profile validation failed"
    txn_begin
    _awg_is_selected=0
    [ "$(cat "$AWG_SELECTED" 2>/dev/null || true)" = "$_awg_id" ] \
        && _awg_is_selected=1
    if [ "$_awg_is_selected" = 1 ] && [ "$(current_engine)" = awg ]; then
        load_settings
        _build_awg_profile "$_awg_draft"
        atomic_write "$_awg_conf" 600 < "$_awg_draft" || fatal "could not store edited profile"
        restart_if_previously_active \
            || fatal "edited profile failed its startup health check; previous profile restored"
    else
        atomic_write "$_awg_conf" 600 < "$_awg_draft" || fatal "could not store edited profile"
        if [ "$_awg_is_selected" = 1 ]; then
            rm -f "$AWG_SELECTED" "$SERVER_CACHE" \
                || fatal "could not clear a stale AmneziaWG selection"
        fi
    fi
    txn_commit
    c_grn "AmneziaWG profile updated."
}

awg_rename() {
    awg_resolve "$1" allow
    _awg_name="$(py "$MKAWG" name --value "$2")" || fatal "invalid display name"
    txn_begin
    printf '%s' "$_awg_name" | atomic_write "$AWG_PROFILES_DIR/${AWG_PICK_ID}.name" 600 \
        || fatal "could not update display name"
    rm -f "$SERVER_CACHE" 2>/dev/null || true
    txn_commit
    awg_resolve "$AWG_PICK_ID" allow
    c_grn "Profile renamed to: $AWG_PICK_NAME"
}

awg_delete() {
    awg_resolve "$1" allow
    txn_begin
    _awg_is_selected=0
    [ "$(cat "$AWG_SELECTED" 2>/dev/null || true)" = "$AWG_PICK_ID" ] \
        && _awg_is_selected=1
    if [ "$_awg_is_selected" = 1 ] && [ "$(current_engine)" = awg ]; then
        systemctl stop "$SERVICE_NAME" 2>/dev/null || fatal "could not stop the active tunnel"
        rm -f "$AWG_SELECTED" "$CONFIG" "$ENGINE_FILE" "$SERVER_CACHE" \
            || fatal "could not remove the active profile state"
        rm -f "$AWG_PICK_PATH" "$AWG_PROFILES_DIR/${AWG_PICK_ID}.name" \
            || fatal "could not remove the active profile files"
        write_service || fatal "could not update the service after deleting the active profile"
        txn_commit
        c_ylw "Deleted active profile '$AWG_PICK_NAME'; the tunnel is now stopped."
    else
        rm -f "$AWG_PICK_PATH" "$AWG_PROFILES_DIR/${AWG_PICK_ID}.name" \
            || fatal "could not remove the profile files"
        if [ "$_awg_is_selected" = 1 ]; then
            rm -f "$AWG_SELECTED" "$SERVER_CACHE" \
                || fatal "could not clear a stale AmneziaWG selection"
        fi
        txn_commit
        c_ylw "Deleted AmneziaWG profile: $AWG_PICK_NAME"
    fi
}

