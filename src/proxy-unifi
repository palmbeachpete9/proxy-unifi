ENGINE_FILE="$ETC_DIR/engine"               # active engine: xray / singbox / xraypool / awg
SERVER_CACHE="$ETC_DIR/.server"             # cached "Server:" display string (menu speed)
MKJSON="$BIN_DIR/mkjson.py"
AUTOSTART_FILE="$ETC_DIR/autostart"         # "enabled" / "disabled" (persisted across boots)
SETTINGS="$ETC_DIR/settings.env"
MKXRAY="$BIN_DIR/mkxray.py"
MKSB="$BIN_DIR/mksingbox.py"
