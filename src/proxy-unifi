# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------
c_red()   { printf '\033[31m%s\033[0m\n' "$*"; }
c_grn()   { printf '\033[32m%s\033[0m\n' "$*"; }
c_ylw()   { printf '\033[33m%s\033[0m\n' "$*"; }
c_bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
info()    { printf '   %s\n' "$*"; }
err()     { c_red "error: $*" >&2; }
fatal()   { err "$*"; exit 1; }

need_root() {
    [ "$(id -u)" = "0" ] || fatal "must be run as root (you are on a UniFi gateway via SSH, use 'root')."
}

_uint() { case "$1" in ""|*[!0-9]*) return 1;; *) return 0;; esac; }

load_settings() {
    [ -f "$SETTINGS" ] || return 0
    while IFS='=' read -r _key _value || [ -n "${_key:-}" ]; do
        case "${_key:-}" in ""|'#'*) continue ;; esac
        case "$_value" in \"*\") _value="${_value#\"}"; _value="${_value%\"}" ;; esac
        case "$_key" in
            WG_LISTEN) case "$_value" in ""|*[!0-9A-Fa-f:.]*) : ;; *) WG_LISTEN="$_value" ;; esac ;;
            WG_PORT)
                if _uint "$_value" && [ "$_value" -ge 1 ] && [ "$_value" -le 65535 ]; then WG_PORT="$_value"; fi ;;
            WG_MTU)
                if _uint "$_value" && [ "$_value" -ge 576 ] && [ "$_value" -le 9000 ]; then WG_MTU="$_value"; fi ;;
            WG_KEEPALIVE)
                if _uint "$_value" && [ "$_value" -le 65535 ]; then WG_KEEPALIVE="$_value"; fi ;;
            XRAY_ADDR) case "$_value" in ""|*[!0-9A-Fa-f:.,/]*) : ;; *) XRAY_ADDR="$_value" ;; esac ;;
            UNIFI_ADDR) case "$_value" in ""|*[!0-9A-Fa-f:.,/]*) : ;; *) UNIFI_ADDR="$_value" ;; esac ;;
            INNER_DNS) case "$_value" in *[!0-9A-Fa-f:.,]*) : ;; *) INNER_DNS="$_value" ;; esac ;;
            LOGLEVEL) case "$_value" in debug|info|warning|error|none) LOGLEVEL="$_value" ;; esac ;;
            PING_MODE) case "$_value" in get|head|tcp|icmp) PING_MODE="$_value" ;; esac ;;
            PING_URL) case "$_value" in https://*) PING_URL="$_value" ;; esac ;;
            PING_TIMEOUT)
                if _uint "$_value" && [ "$_value" -ge 1 ] && [ "$_value" -le 60 ]; then PING_TIMEOUT="$_value"; fi ;;
            SUB_REFRESH_HOURS)
                if _uint "$_value" && [ "$_value" -ge 1 ] && [ "$_value" -le 8760 ]; then SUB_REFRESH_HOURS="$_value"; fi ;;
            SUB_USER_AGENT)
                case "$_value" in
                    "$SUB_USER_AGENT_LEGACY_DEFAULT")
                        # The old neutral default makes Happ/Remnawave-style
                        # providers return generic ss:// rows instead of JSON.
                        # Treat it as unset during upgrades, while preserving
                        # any user-chosen compatibility UA.
                        : ;;
                    ""|*\"*|*\\*) : ;;
                    *) if [ "${#_value}" -le 120 ] \
                          && ! LC_ALL=C printf '%s' "$_value" | grep -q '[^ -~]'; then
                           SUB_USER_AGENT="$_value"
                       fi ;;
                esac ;;
        esac
    done < "$SETTINGS"
}

atomic_write() {
    _aw_dest="$1"; _aw_mode="${2:-600}"
    py -c '
import os, sys, tempfile
destination = sys.argv[1]
directory = os.path.dirname(destination) or "."
os.makedirs(directory, exist_ok=True)
fd, temporary = tempfile.mkstemp(prefix=".write.", dir=directory)
try:
    os.fchmod(fd, int(sys.argv[2], 8))
    with os.fdopen(fd, "wb") as output:
        fd = -1
        while True:
            chunk = sys.stdin.buffer.read(1024 * 1024)
            if not chunk:
                break
            output.write(chunk)
        output.flush()
        os.fsync(output.fileno())
    os.replace(temporary, destination)
    flags = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0)
    directory_fd = os.open(directory, flags)
    try:
        os.fsync(directory_fd)
    finally:
        os.close(directory_fd)
except Exception:
    if fd >= 0:
        os.close(fd)
    try:
        os.unlink(temporary)
    except FileNotFoundError:
        pass
    raise
' "$_aw_dest" "$_aw_mode" 2>/dev/null
}

save_settings() {
    mkdir -p "$ETC_DIR"
    atomic_write "$SETTINGS" 600 <<EOF || fatal "could not persist settings"
# proxy-unifi settings - parsed as data, never sourced as shell code.
WG_LISTEN="$WG_LISTEN"
WG_PORT="$WG_PORT"
WG_MTU="$WG_MTU"
WG_KEEPALIVE="$WG_KEEPALIVE"
XRAY_ADDR="$XRAY_ADDR"
UNIFI_ADDR="$UNIFI_ADDR"
INNER_DNS="$INNER_DNS"
LOGLEVEL="$LOGLEVEL"
PING_MODE="$PING_MODE"
PING_URL="$PING_URL"
PING_TIMEOUT="$PING_TIMEOUT"
SUB_REFRESH_HOURS="$SUB_REFRESH_HOURS"
SUB_USER_AGENT="$SUB_USER_AGENT"
EOF
}

have() { command -v "$1" >/dev/null 2>&1; }

core_version() {
    "$1" version 2>/dev/null | {
        _version_line=""
        IFS= read -r _version_line || true
        printf '%s\n' "$_version_line"
    }
}

