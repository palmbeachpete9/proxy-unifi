AWG_DRAFT_DIR="$ROOT/.awg-drafts"            # root-only editor scratch space
SERVICE_NAME="proxy-unifi"
SERVICE_USER="proxy-unifi"
SERVICE_GROUP="proxy-unifi"
# (no RUN_DIR: xray runs under systemd, no pidfile needed)
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
REFRESH_SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}-refresh.service"
REFRESH_TIMER_FILE="/etc/systemd/system/${SERVICE_NAME}-refresh.timer"
ONBOOT_DST="/data/on_boot.d/15-proxy-unifi.sh"
