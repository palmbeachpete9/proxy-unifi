#!/bin/sh
# proxy-unifi - GUI-less Xray-core proxy client (VLESS/Trojan/Shadowsocks) for UniFi Cloud Gateways.
#
# It runs an Xray WireGuard inbound that the gateway's *native* WireGuard VPN
# Client connects to over loopback, and forwards everything out a proxy server.
# Because the tunnel is a real, controller-managed WireGuard VPN Client, it shows
# up in the UniFi UI (VPN -> VPN Client) and in Policy Engine -> Policy Table.
#
# POSIX sh on purpose: UniFi OS ships dash/busybox-ish environments.

set -eu

# --------------------------------------------------------------------------
# Paths / constants
# --------------------------------------------------------------------------
ROOT="/data/proxy-unifi"
BIN_DIR="$ROOT/bin"
ETC_DIR="$ROOT/etc"
WG_DIR="$ETC_DIR/wg"
XRAY="$BIN_DIR/xray"
SBIN="$BIN_DIR/sing-box"
CONFIG="$ETC_DIR/config.json"
OUTBOUND_LINK="$ETC_DIR/link.txt"
POOL_DIR="$ETC_DIR/pool"                    # xray -confdir dir for a JSON balancer profile
POOL_SRC="$ETC_DIR/pool.json"               # the imported provider profile (verbatim source)
ENGINE_FILE="$ETC_DIR/engine"               # active engine: "xray" / "singbox" / "xraypool"
MKJSON="$BIN_DIR/mkjson.py"
AUTOSTART_FILE="$ETC_DIR/autostart"         # "enabled" / "disabled" (persisted across boots)
SETTINGS="$ETC_DIR/settings.env"
MKCONFIG="$BIN_DIR/mkconfig.py"
MKSB="$BIN_DIR/mksingbox.py"
MKSUB="$BIN_DIR/mksub.py"
SUB_DIR="$ETC_DIR/subscription"
SUB_URL_FILE="$SUB_DIR/url.txt"             # subscription URL (mode 600)
SUB_CATALOG="$SUB_DIR/catalog.json"         # cached parsed nodes
SUB_HWID_FILE="$SUB_DIR/hwid"               # stable per-install device id
SUB_SELECTED="$SUB_DIR/selected"            # id of the node currently activated
SERVICE_NAME="proxy-unifi"
# (no RUN_DIR: xray runs under systemd, no pidfile needed)
SERVICE_FILE="/etc/systemd/system/${SERVICE_NAME}.service"
ONBOOT_DST="/data/on_boot.d/15-proxy-unifi.sh"

# Legacy SIP003 plugin unit (from when xray ran external plugins). Kept only so
# uninstall / migration can clean up any leftovers on older installs.
PLUGIN_SERVICE_NAME="proxy-unifi-plugin"
PLUGIN_SERVICE_FILE="/etc/systemd/system/${PLUGIN_SERVICE_NAME}.service"

XRAY_RELEASE_BASE="https://github.com/XTLS/Xray-core/releases/latest/download"
GEO_BASE="https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download"
SINGBOX_RELEASES="https://github.com/SagerNet/sing-box/releases"

# defaults (overridable via settings.env)
WG_LISTEN="127.0.0.1"
WG_PORT="51821"
WG_MTU="1340"
WG_KEEPALIVE="25"
XRAY_ADDR="10.7.0.1/32"
UNIFI_ADDR="10.7.0.2/32"
INNER_DNS="8.8.8.8"
LOGLEVEL="warning"
PING_MODE="get"
PING_URL="https://www.gstatic.com/generate_204"
PING_TIMEOUT="5"

# --------------------------------------------------------------------------
# Helpers
# --------------------------------------------------------------------------
c_red()   { printf '\033[31m%s\033[0m\n' "$*"; }
c_grn()   { printf '\033[32m%s\033[0m\n' "$*"; }
c_ylw()   { printf '\033[33m%s\033[0m\n' "$*"; }
c_bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
info()    { printf '   %s\n' "$*"; }
err()     { c_red "error: $*" >&2; }
fatal()   { err "$*"; exit 1; }

need_root() {
    [ "$(id -u)" = "0" ] || fatal "must be run as root (you are on a UniFi gateway via SSH, use 'root')."
}

load_settings() {
    # shellcheck source=/dev/null
    [ -f "$SETTINGS" ] && . "$SETTINGS" || true
}

save_settings() {
    mkdir -p "$ETC_DIR"
    cat > "$SETTINGS" <<EOF
# proxy-unifi settings - managed by the CLI ('proxy set <key> <value>'). Safe to edit by hand.
WG_LISTEN="$WG_LISTEN"
WG_PORT="$WG_PORT"
WG_MTU="$WG_MTU"
WG_KEEPALIVE="$WG_KEEPALIVE"
XRAY_ADDR="$XRAY_ADDR"
UNIFI_ADDR="$UNIFI_ADDR"
INNER_DNS="$INNER_DNS"
LOGLEVEL="$LOGLEVEL"
PING_MODE="$PING_MODE"
PING_URL="$PING_URL"
PING_TIMEOUT="$PING_TIMEOUT"
EOF
}

have() { command -v "$1" >/dev/null 2>&1; }

# D20: only create/remove /usr/bin/proxy if it is absent or already OUR symlink,
# never clobbering an unrelated file someone else owns.
PROXY_LINK="/usr/bin/proxy"
proxy_link_is_ours() {
    [ -L "$PROXY_LINK" ] || return 1
    case "$(readlink "$PROXY_LINK" 2>/dev/null)" in
        "$BIN_DIR/proxy-unifi") return 0 ;;
        *) return 1 ;;
    esac
}
install_proxy_link() {
    if [ -e "$PROXY_LINK" ] && [ ! -L "$PROXY_LINK" ]; then
        c_ylw "warning: $PROXY_LINK exists and is not a symlink; leaving it untouched."
        return 0
    fi
    if [ -L "$PROXY_LINK" ] && ! proxy_link_is_ours; then
        c_ylw "warning: $PROXY_LINK points elsewhere; leaving it untouched."
        return 0
    fi
    ln -sf "$BIN_DIR/proxy-unifi" "$PROXY_LINK"
}
remove_proxy_link() {
    # remove only if it is absent-as-file or our own symlink
    if [ -L "$PROXY_LINK" ] && ! proxy_link_is_ours; then
        c_ylw "note: $PROXY_LINK points elsewhere; not removing it."
        return 0
    fi
    [ -L "$PROXY_LINK" ] && rm -f "$PROXY_LINK" || true
}

py() {
    if have python3; then python3 "$@";
    elif have python; then python "$@";
    else fatal "python3 is required but was not found on this gateway.";
    fi
}

# Generate a WireGuard keypair -> prints "PRIVATE PUBLIC" on one line.
gen_keypair() {
    if have wg; then
        _priv="$(wg genkey)"
        _pub="$(printf '%s' "$_priv" | wg pubkey)"
    elif have openssl; then
        _tmp="$(mktemp)" || fatal "could not create temp file"
        # remove the key temp on any exit/interrupt, not just the success path
        # shellcheck disable=SC2064
        trap "rm -f '$_tmp'" EXIT INT TERM HUP
        openssl genpkey -algorithm X25519 -out "$_tmp" 2>/dev/null \
            || fatal "openssl could not generate an X25519 key"
        _priv="$(openssl pkey -in "$_tmp" -outform DER 2>/dev/null | tail -c 32 | base64)"
        _pub="$(openssl pkey -in "$_tmp" -pubout -outform DER 2>/dev/null | tail -c 32 | base64)"
        rm -f "$_tmp"
        trap - EXIT INT TERM HUP
    else
        fatal "need either 'wg' or 'openssl' to generate WireGuard keys"
    fi
    printf '%s %s\n' "$_priv" "$_pub"
}

ensure_keys() {
    mkdir -p "$WG_DIR"
    chmod 700 "$WG_DIR"
    # migrate legacy key names (xray-only era) -> engine-neutral names, so an
    # upgrade reuses the existing keypair instead of regenerating (which would
    # break the already-applied UniFi WireGuard VPN Client).
    if [ -f "$WG_DIR/xray_private.key" ] && [ ! -f "$WG_DIR/wg_private.key" ]; then
        mv "$WG_DIR/xray_private.key" "$WG_DIR/wg_private.key"
    fi
    if [ -f "$WG_DIR/xray_public.key" ] && [ ! -f "$WG_DIR/wg_public.key" ]; then
        mv "$WG_DIR/xray_public.key" "$WG_DIR/wg_public.key"
    fi
    # Each keypair is repaired independently so a missing/lost file never destroys
    # a still-valid pair. If a private key exists but its public is missing, derive
    # the public from the private (when 'wg' is available) instead of regenerating.
    _ensure_pair wg
    _ensure_pair unifi
    chmod 600 "$WG_DIR"/*.key 2>/dev/null || true
}

# _ensure_pair <prefix>: guarantee $WG_DIR/<prefix>_private.key + _public.key exist
# and are CONSISTENT (public is actually derived from private), repairing only the
# public half when possible and never rotating a valid private key needlessly.
_ensure_pair() {
    _pp="$WG_DIR/$1_private.key"; _pub="$WG_DIR/$1_public.key"
    if [ -s "$_pp" ] && have wg; then
        # derive the correct public key from the existing private key
        _derived="$(wg pubkey < "$_pp" 2>/dev/null)"
        if [ -n "$_derived" ]; then
            if [ ! -s "$_pub" ] || [ "$_derived" != "$(cat "$_pub" 2>/dev/null)" ]; then
                # repair only the public half to match the (kept) private key
                printf '%s' "$_derived" > "$_pub"; chmod 600 "$_pub"
            fi
            return 0
        fi
        # private key is unreadable/invalid by wg -> fall through and regenerate
    elif [ -s "$_pp" ] && [ -s "$_pub" ]; then
        return 0                                   # no 'wg' to verify; trust both
    fi
    # otherwise (re)generate the whole pair
    info "generating WireGuard keypair: $1 ..."
    _kp="$(gen_keypair)"
    printf '%s' "${_kp% *}" > "$_pp"; printf '%s' "${_kp#* }" > "$_pub"
    chmod 600 "$_pp" "$_pub"
}

arch_slug() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64-v8a" ;;
        x86_64|amd64)  echo "64" ;;
        armv7l|armhf)  echo "arm32-v7a" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# --------------------------------------------------------------------------
# Engine selection (xray vs sing-box)
# --------------------------------------------------------------------------
# Which engine handles a link: "xray", "singbox", or "" (unsupported).
engine_for_link() {
    case "$1" in
        vless://*|vmess://*|trojan://*) echo xray; return ;;
        hysteria2://*|hy2://*|tuic://*) echo singbox; return ;;
        ss://*)
            _pn="$(py "$MKCONFIG" --link "$1" --print-plugin 2>/dev/null | cut -f1)"
            if [ -z "$_pn" ]; then echo xray; return; fi   # plain SS -> xray
            case "$_pn" in
                obfs-local|simple-obfs|v2ray-plugin) echo singbox ;;  # sing-box runs these in-process
                *) echo "" ;;                                        # other SIP003 plugins: unsupported
            esac
            return ;;
    esac
    echo ""
}

current_engine() {
    # Trust the engine marker only if it is one of the known values; otherwise
    # infer from on-disk state (an empty/corrupt marker must not default to the
    # wrong core, e.g. running a hysteria2 link under xray).
    _ce="$(cat "$ENGINE_FILE" 2>/dev/null || true)"
    case "$_ce" in
        xray|singbox|xraypool) echo "$_ce"; return ;;
    esac
    # a pool dir present means we're in pool mode
    if [ -f "$POOL_DIR/99-overlay.json" ]; then echo xraypool; return; fi
    if [ -f "$OUTBOUND_LINK" ]; then
        _ce="$(engine_for_link "$(cat "$OUTBOUND_LINK")")"
        [ -n "$_ce" ] && { echo "$_ce"; return; }
    fi
    echo xray
}

# map our (xray-style) loglevel to sing-box's vocabulary
sb_loglevel() {
    case "$LOGLEVEL" in
        warning) echo warn ;;
        none)    echo fatal ;;
        debug|info|error) echo "$LOGLEVEL" ;;
        *) echo warn ;;
    esac
}

sb_arch() {
    case "$(uname -m)" in
        aarch64|arm64) echo "arm64" ;;
        x86_64|amd64)  echo "amd64" ;;
        armv7l|armhf)  echo "armv7" ;;
        *) fatal "unsupported architecture: $(uname -m)" ;;
    esac
}

# Download <url> to <dest> using whichever of curl/wget exists. Returns nonzero on
# failure (and removes a partial file). One place, so tag-resolution and the
# tarball download use the same available tool.
download_to() {
    _d_url="$1"; _d_dst="$2"
    if have curl; then
        curl -fsSL "$_d_url" -o "$_d_dst" || { rm -f "$_d_dst"; return 1; }
    elif have wget; then
        wget -qO "$_d_dst" "$_d_url" || { rm -f "$_d_dst"; return 1; }
    else
        return 1
    fi
}

# Resolve the latest tag from a .../releases/latest redirect with the available tool.
resolve_latest_tag() {
    if have curl; then
        curl -fsSLI "$1/latest" 2>/dev/null | tr -d '\r'
    elif have wget; then
        wget -qS --max-redirect=0 "$1/latest" -O /dev/null 2>&1 | tr -d '\r'
    fi | awk -F'/tag/' 'tolower($0) ~ /location:/ {print $2}' | awk '{print $1}' | tail -1
}

# compute the SHA-256 of a file with whatever tool exists; echoes the hex digest
sha256_of() {
    if have sha256sum; then sha256sum "$1" | awk '{print $1}'
    elif have shasum;   then shasum -a 256 "$1" | awk '{print $1}'
    else py -c "import hashlib,sys;print(hashlib.sha256(open(sys.argv[1],'rb').read()).hexdigest())" "$1" 2>/dev/null
    fi
}

# Verify $1 (a downloaded file) against the expected sha256 in $2 (a string).
# Integrity check only (the digest is published next to the file by upstream).
# Returns 0 on match, 1 on mismatch, 2 if no expected hash / cannot hash.
verify_sha256() {
    [ -n "${2:-}" ] || return 2
    _got="$(sha256_of "$1")"
    [ -n "$_got" ] || return 2
    [ "$_got" = "$2" ] && return 0
    err "checksum mismatch for $(basename "$1") (got $_got, expected $2)"
    return 1
}

cmd_install_singbox() {
    mkdir -p "$BIN_DIR"
    have tar || { err "need tar to install sing-box"; return 1; }
    { have curl || have wget; } || { err "need curl or wget to download sing-box"; return 1; }
    _sa="$(sb_arch)"
    _tag="$(resolve_latest_tag "$SINGBOX_RELEASES")"
    [ -n "$_tag" ] || { err "could not resolve sing-box latest version"; return 1; }
    _ver="${_tag#v}"
    _url="$SINGBOX_RELEASES/download/${_tag}/sing-box-${_ver}-linux-${_sa}.tar.gz"
    _tmp="$(mktemp -d)"
    info "downloading sing-box ${_tag} (${_sa}) ..."
    download_to "$_url" "$_tmp/sb.tgz" || { rm -rf "$_tmp"; err "sing-box download failed"; return 1; }
    tar xzf "$_tmp/sb.tgz" -C "$_tmp" || { rm -rf "$_tmp"; err "could not extract sing-box"; return 1; }
    _b="$(find "$_tmp" -name sing-box -type f | head -1)"
    [ -n "$_b" ] || { rm -rf "$_tmp"; err "sing-box binary not found in archive"; return 1; }
    chmod 0755 "$_b"
    # verify the staged binary runs
    "$_b" version >/dev/null 2>&1 || { rm -rf "$_tmp"; err "downloaded sing-box binary did not run"; return 1; }
    # D15: if sing-box is the active engine and we have a config, validate it
    # against the NEW binary before switching; keep a backup for rollback.
    if [ -x "$SBIN" ] && [ "$(current_engine)" = "singbox" ] && [ -f "$CONFIG" ]; then
        "$_b" check -c "$CONFIG" >/dev/null 2>&1 \
            || { rm -rf "$_tmp"; err "the new sing-box rejects your current config; keeping the old version"; return 1; }
    fi
    [ -x "$SBIN" ] && cp -f "$SBIN" "$SBIN.bak" 2>/dev/null || true
    install -m 0755 "$_b" "$SBIN.new" || { rm -rf "$_tmp"; rm -f "$SBIN.new"; err "could not install sing-box binary"; return 1; }
    mv -f "$SBIN.new" "$SBIN" || { rm -rf "$_tmp"; err "could not activate sing-box binary"; return 1; }
    if ! "$SBIN" version >/dev/null 2>&1; then
        [ -f "$SBIN.bak" ] && mv -f "$SBIN.bak" "$SBIN"
        rm -rf "$_tmp"; err "new sing-box failed to run; rolled back to the previous version"; return 1
    fi
    rm -f "$SBIN.bak" 2>/dev/null || true
    rm -rf "$_tmp"
    c_grn "sing-box installed: $("$SBIN" version 2>/dev/null | head -1)"
}

ensure_singbox() {
    [ -x "$SBIN" ] || cmd_install_singbox || true
    [ -x "$SBIN" ] || fatal "sing-box is required for this link but could not be installed"
}

# --------------------------------------------------------------------------
# Commands
# --------------------------------------------------------------------------

cmd_install_binary() {
    mkdir -p "$BIN_DIR"
    slug="$(arch_slug)"
    url="${XRAY_RELEASE_BASE}/Xray-linux-${slug}.zip"
    tmp="$(mktemp -d)" || fatal "could not create temp dir"
    # shellcheck disable=SC2064
    trap "rm -rf '$tmp'" EXIT INT TERM HUP
    info "downloading xray-core ($slug) ..."
    download_to "$url" "$tmp/xray.zip" || fatal "download failed: $url"
    # D21: verify the archive against the release's published SHA-256 (.dgst). This
    # is integrity (catches corruption/truncation/MITM-without-cert), not signing.
    if download_to "$url.dgst" "$tmp/xray.dgst" 2>/dev/null; then
        _want="$(awk -F'= ' 'tolower($1) ~ /sha2-256/ {print tolower($2)}' "$tmp/xray.dgst" | tr -d ' \r' | head -1)"
        verify_sha256 "$tmp/xray.zip" "$_want"
        case $? in
            0) info "xray-core checksum verified." ;;
            1) fatal "xray-core download failed checksum verification (aborting)" ;;
            2) c_ylw "xray-core checksum could not be computed; continuing on HTTPS trust." ;;
        esac
    else
        c_ylw "xray-core checksum file unavailable; continuing on HTTPS trust."
    fi
    if have unzip; then
        unzip -oq "$tmp/xray.zip" -d "$tmp" || fatal "unzip failed"
    else
        py -c "import zipfile,sys; zipfile.ZipFile('$tmp/xray.zip').extractall('$tmp')" \
            || fatal "could not extract xray.zip (no unzip and python failed)"
    fi
    [ -f "$tmp/xray" ] || fatal "downloaded archive did not contain an xray binary"
    chmod 0755 "$tmp/xray"
    "$tmp/xray" version >/dev/null 2>&1 || fatal "downloaded xray binary did not run"
    # D15: if a config already exists, validate it against the NEW binary before
    # switching, and keep a backup of the working binary so we can roll back.
    _had_xray=0; [ -x "$XRAY" ] && _had_xray=1
    if [ "$_had_xray" = 1 ] && { [ -f "$CONFIG" ] || [ -f "$POOL_DIR/99-overlay.json" ]; }; then
        if [ -f "$POOL_DIR/99-overlay.json" ]; then
            "$tmp/xray" run -test -confdir "$POOL_DIR" >/dev/null 2>&1 \
                || fatal "the new xray-core rejects your current profile; keeping the old version"
        elif [ -f "$CONFIG" ] && [ "$(current_engine)" != "singbox" ]; then
            "$tmp/xray" run -test -config "$CONFIG" -format json >/dev/null 2>&1 \
                || fatal "the new xray-core rejects your current config; keeping the old version"
        fi
    fi
    [ "$_had_xray" = 1 ] && cp -f "$XRAY" "$XRAY.bak" 2>/dev/null || true
    install -m 0755 "$tmp/xray" "$XRAY.new" || fatal "could not stage xray binary"
    mv -f "$XRAY.new" "$XRAY" || fatal "could not install xray binary"
    if ! "$XRAY" version >/dev/null 2>&1; then
        # roll back to the previous binary
        [ -f "$XRAY.bak" ] && mv -f "$XRAY.bak" "$XRAY"
        fatal "new xray-core failed to run; rolled back to the previous version"
    fi
    rm -f "$XRAY.bak" 2>/dev/null || true
    # geo data ships inside the xray zip, so it refreshes on every core update.
    if [ -f "$tmp/geoip.dat" ];   then install -m 0644 "$tmp/geoip.dat"   "$BIN_DIR/geoip.dat";   fi
    if [ -f "$tmp/geosite.dat" ]; then install -m 0644 "$tmp/geosite.dat" "$BIN_DIR/geosite.dat"; fi
    rm -rf "$tmp"; trap - EXIT INT TERM HUP
    c_grn "xray-core installed: $("$XRAY" version 2>/dev/null | head -1)"
    # Pre-stage / refresh the sing-box engine (best-effort).
    cmd_install_singbox || c_ylw "sing-box not installed (continuing); needed only for ss+obfs/v2ray-plugin, hysteria2, tuic links"
}

write_service() {
    # ExecStart depends on the active engine. Prefer the recorded engine; if the
    # engine file was lost (e.g. after a partial restore) fall back to inferring it.
    case "$(current_engine)" in
        singbox)  _exec="$SBIN run -c $CONFIG";        _cond="$CONFIG" ;;
        xraypool) _exec="$XRAY run -confdir $POOL_DIR"; _cond="$POOL_DIR/99-overlay.json" ;;
        *)        _exec="$XRAY run -config $CONFIG";    _cond="$CONFIG" ;;
    esac
    cat > "$SERVICE_FILE" <<EOF
[Unit]
Description=proxy-unifi (WireGuard->proxy bridge)
After=network-online.target nss-lookup.target
Wants=network-online.target
# Don't crash-loop before a link/profile has been imported.
ConditionPathExists=$_cond

[Service]
Type=simple
ExecStart=$_exec
Environment=XRAY_LOCATION_ASSET=$BIN_DIR
WorkingDirectory=$ROOT
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload 2>/dev/null || true
}

# Remove any leftover SIP003 plugin unit from older (external-plugin) installs.
cleanup_legacy_plugin() {
    if [ -f "$PLUGIN_SERVICE_FILE" ]; then
        systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
        rm -f "$PLUGIN_SERVICE_FILE"
        systemctl daemon-reload 2>/dev/null || true
    fi
}

install_service() {
    cleanup_legacy_plugin
    install_proxy_link            # safe (D20): only (re)links our own symlink
    write_service
    # Honor the user's persisted autostart choice across reboots/firmware wipes.
    # Default (no marker) = enabled, matching prior behavior.
    if [ -f "$AUTOSTART_FILE" ] && [ "$(cat "$AUTOSTART_FILE")" = "disabled" ]; then
        systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || true
    else
        systemctl enable "$SERVICE_NAME" >/dev/null 2>&1 || true
    fi
}

# Build + validate a config from the given link and, only on success, swap it
# into place. Never mutates stored state (link.txt) on failure.
# Secrets (the proxy link + WireGuard private key) are passed to the generator
# through a mode-600 JSON file, never argv (process-list safety + no ARG_MAX).
_build_config() {
    _bl="$1"
    ensure_keys
    _eng="$(engine_for_link "$_bl")"
    [ -n "$_eng" ] || fatal "unsupported link (expected vless/vmess/trojan/ss/hysteria2/tuic)"
    wg_priv="$(cat "$WG_DIR/wg_private.key")" || fatal "could not read WireGuard key"
    unifi_pub="$(cat "$WG_DIR/unifi_public.key")" || fatal "could not read WireGuard key"
    mkdir -p "$ETC_DIR" || fatal "could not create $ETC_DIR"
    tmpcfg="$(mktemp "$ETC_DIR/.cfg.XXXXXX")" || fatal "could not create temp file"
    _inf="$(mktemp "$ETC_DIR/.in.XXXXXX")" || { rm -f "$tmpcfg"; fatal "could not create temp file"; }
    # shellcheck disable=SC2064
    trap "rm -f '$tmpcfg' '$_inf'" EXIT INT TERM HUP
    chmod 600 "$_inf"
    # JSON input doc with the secret-bearing fields
    py - "$_inf" "$_bl" "$wg_priv" "$unifi_pub" <<'PYEOF' || fatal "could not stage generator input"
import json,sys
open(sys.argv[1],"w").write(json.dumps({"link":sys.argv[2],"secret_key":sys.argv[3],"peer_pubkey":sys.argv[4]}))
PYEOF
    if [ "$_eng" = "singbox" ]; then
        ensure_singbox
        py "$MKSB" --input-file "$_inf" --port "$WG_PORT" \
            --address "$XRAY_ADDR" --mtu "$WG_MTU" --loglevel "$(sb_loglevel)" \
            > "$tmpcfg" || fatal "config generation failed (check the link)"
        if [ -x "$SBIN" ]; then
            "$SBIN" check -c "$tmpcfg" >/dev/null 2>&1 || fatal "sing-box rejected the generated config"
        fi
    else
        set --
        [ -n "$INNER_DNS" ] && set -- --dns "$INNER_DNS"
        py "$MKCONFIG" --input-file "$_inf" \
            --listen "$WG_LISTEN" --port "$WG_PORT" \
            --address "$XRAY_ADDR" --mtu "$WG_MTU" \
            --keepalive "$WG_KEEPALIVE" --loglevel "$LOGLEVEL" \
            "$@" \
            > "$tmpcfg" || fatal "config generation failed (check the link)"
        # -format json is required because xray infers format from the extension.
        if [ -x "$XRAY" ]; then
            "$XRAY" run -test -config "$tmpcfg" -format json >/dev/null 2>&1 \
                || fatal "xray rejected the generated config (-test failed)"
        fi
    fi
    rm -f "$_inf"
    [ -s "$tmpcfg" ] || fatal "generated config is empty"
    mv -f "$tmpcfg" "$CONFIG" || fatal "could not install config"
    chmod 600 "$CONFIG"
    trap - EXIT INT TERM HUP
    printf '%s' "$_eng" > "$ENGINE_FILE" || fatal "could not write engine marker"
    # Refresh the systemd unit so ExecStart matches the (possibly changed) engine.
    [ -f "$SERVICE_FILE" ] && write_service || true
}

regen_config() {
    if [ -f "$POOL_SRC" ] && [ "$(current_engine)" = "xraypool" ]; then
        _build_pool "$POOL_SRC"
    else
        [ -f "$OUTBOUND_LINK" ] || fatal "no proxy link imported yet. Run 'proxy' and choose option 1."
        _build_config "$(cat "$OUTBOUND_LINK")"
    fi
}

# Build + validate an Xray JSON *profile* (balancer/pool) into the -confdir POOL_DIR.
# The provider JSON is kept verbatim (sanitized for platform paths) and a WG-inbound
# overlay replaces its local entry by tag. Only swaps state in on a clean -test.
_build_pool() {
    _pf="$1"
    [ -x "$XRAY" ] || fatal "xray-core is required for JSON balancer profiles"
    ensure_keys
    mkdir -p "$ETC_DIR" || fatal "could not create $ETC_DIR"
    _stage="$(mktemp -d "$ETC_DIR/.pool.XXXXXX")" || fatal "could not create temp dir"
    # shellcheck disable=SC2064
    trap "rm -rf '$_stage'" EXIT INT TERM HUP
    py "$MKJSON" overlay --profile "$_pf" \
        --out-provider "$_stage/01-provider.json" \
        --out-overlay "$_stage/99-overlay.json" \
        --port "$WG_PORT" \
        --secret-key-file "$WG_DIR/wg_private.key" \
        --peer-pubkey-file "$WG_DIR/unifi_public.key" \
        --address "$XRAY_ADDR" --mtu "$WG_MTU" --loglevel "$LOGLEVEL" \
        >/dev/null || fatal "could not build pool profile (unsupported or invalid JSON)"
    "$XRAY" run -test -confdir "$_stage" >/dev/null 2>&1 \
        || fatal "xray rejected the pool profile (-test failed)"
    chmod 600 "$_stage"/*.json 2>/dev/null || true
    # swap the whole pool dir in atomically
    rm -rf "$POOL_DIR.old" 2>/dev/null || true
    [ -d "$POOL_DIR" ] && mv "$POOL_DIR" "$POOL_DIR.old"
    mv "$_stage" "$POOL_DIR" || { [ -d "$POOL_DIR.old" ] && mv "$POOL_DIR.old" "$POOL_DIR"; fatal "could not install pool dir"; }
    rm -rf "$POOL_DIR.old" 2>/dev/null || true
    trap - EXIT INT TERM HUP
    printf 'xraypool' > "$ENGINE_FILE" || fatal "could not write engine marker"
    # pool mode has no single config.json; clear a stale one so status is accurate
    rm -f "$CONFIG" 2>/dev/null || true
    [ -f "$SERVICE_FILE" ] && write_service || true
}

# Import a JSON balancer/pool profile from a file (or piped content already saved
# to a temp file). $1 = path to the provider JSON.
cmd_import_json() {
    _src="$1"
    [ -s "$_src" ] || fatal "empty profile"
    load_settings
    # build first; only commit POOL_SRC on success (never clobber a working setup)
    _build_pool "$_src"
    cp -f "$_src" "$POOL_SRC" || fatal "could not store profile"
    chmod 600 "$POOL_SRC"
    # a pool import supersedes any single link + subscription selection
    rm -f "$OUTBOUND_LINK" 2>/dev/null || true
    [ "${_FROM_SUB:-0}" = "1" ] || rm -f "$SUB_SELECTED" 2>/dev/null || true
    save_settings
    if restart_service; then c_grn "Imported balancer profile and applied."
    else c_ylw "Imported, but the service did not come up — check 'View logs'."; fi
    echo
    cmd_wg_config
}

cmd_import() {
    [ $# -ge 1 ] || fatal "usage: proxy import <vless:// | vmess:// | trojan:// | ss:// | hysteria2:// | tuic:// ...>"
    link="$1"
    case "$link" in
        vless://*|vmess://*|trojan://*|ss://*|hysteria2://*|hy2://*|tuic://*) : ;;
        *) fatal "unsupported link (expected vless://, vmess://, trojan://, ss://, hysteria2:// or tuic://)" ;;
    esac
    load_settings
    # Build + validate the NEW link FIRST. On any failure this fatals before we
    # touch link.txt, so a bad import never clobbers a working configuration.
    _build_config "$link"
    mkdir -p "$ETC_DIR"
    printf '%s' "$link" > "$OUTBOUND_LINK"
    chmod 600 "$OUTBOUND_LINK"
    # a single-link import supersedes any active pool profile
    rm -rf "$POOL_DIR" "$POOL_SRC" 2>/dev/null || true
    save_settings
    # A manual import detaches any subscription selection (so a later 'sub refresh'
    # won't think this hand-picked link came from the subscription). sub_select sets
    # _FROM_SUB=1 to keep its own marker.
    [ "${_FROM_SUB:-0}" = "1" ] || rm -f "$SUB_SELECTED" 2>/dev/null || true
    # Apply immediately (starts the service even if autostart is off; the unit's
    # ConditionPathExists is now satisfied because config.json exists).
    if restart_service; then c_grn "Imported and applied."
    else c_ylw "Imported, but the service did not come up — check 'View logs'."; fi
    echo
    cmd_wg_config
}

cmd_wg_config() {
    [ -f "$WG_DIR/unifi_private.key" ] || fatal "no keys yet. Run 'proxy' and choose option 1 to import a link first."
    load_settings
    upriv="$(cat "$WG_DIR/unifi_private.key")"
    xpub="$(cat "$WG_DIR/wg_public.key")"
    c_bold "================  UniFi WireGuard VPN Client  ================"
    echo
    echo "In unifi.ui.com: Settings -> VPN -> VPN Client -> Create New (WireGuard)."
    echo "Either enter these manually, or upload the .conf below:"
    echo
    printf '%-19s %s\n' "Private Key:"        "$upriv"
    printf '%-19s %s\n' "Public Key (peer):"  "$xpub"
    printf '%-19s %s\n' "Endpoint:"           "${WG_LISTEN}:${WG_PORT}"
    printf '%-19s %s\n' "Pre-shared Key:"     "(leave empty)"
    printf '%-19s %s\n' "Address/Local IP:"   "$UNIFI_ADDR"
    printf '%-19s %s\n' "Allowed IPs:"        "0.0.0.0/0, ::/0"
    printf '%-19s %s\n' "MTU:"                "$WG_MTU"
    [ -n "$INNER_DNS" ] && printf '%-19s %s\n' "DNS:" "$INNER_DNS"
    echo
    c_ylw "Save this as a .conf and use 'Upload Configuration File':"
    echo "----------------------------------------------------------------"
    cat <<EOF
[Interface]
PrivateKey = $upriv
Address = $UNIFI_ADDR
$( [ -n "$INNER_DNS" ] && echo "DNS = $INNER_DNS" )
MTU = $WG_MTU

[Peer]
PublicKey = $xpub
Endpoint = ${WG_LISTEN}:${WG_PORT}
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = $WG_KEEPALIVE
EOF
    echo "----------------------------------------------------------------"
    echo
    echo "After it connects, go to Policy Engine -> Policy Table and create a"
    echo "Traffic Route that sends your chosen VLAN/clients through this VPN Client."
    c_bold "============================================================="
}

cmd_status() {
    load_settings
    act="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)"
    ena="$(systemctl is-enabled "$SERVICE_NAME" 2>/dev/null || true)"
    echo "service:   ${act:-unknown} / ${ena:-disabled}"
    _eng="$(current_engine)"
    echo "engine:    $_eng"
    if [ "$_eng" = "singbox" ]; then
        if [ -x "$SBIN" ]; then echo "core:      $("$SBIN" version 2>/dev/null | head -1)"; else echo "core:      sing-box not installed"; fi
    else
        if [ -x "$XRAY" ]; then echo "core:      $("$XRAY" version 2>/dev/null | head -1)"; else echo "core:      xray not installed"; fi
    fi
    echo "server:    $(current_server)"
    # sing-box has no listen-address option, so it binds the WG port on all
    # interfaces; report that honestly rather than implying loopback-only.
    if [ "$_eng" = "singbox" ]; then
        echo "wg listen: 0.0.0.0:${WG_PORT} (all interfaces; WG-key gated)  mtu=${WG_MTU}"
    else
        echo "wg listen: ${WG_LISTEN}:${WG_PORT}  mtu=${WG_MTU}"
    fi
    if have ss; then
        if ss -lun 2>/dev/null | grep -q ":${WG_PORT}\b"; then c_grn "udp/${WG_PORT}: listening"; else c_ylw "udp/${WG_PORT}: not listening"; fi
    fi
}

cmd_logs()    { shift || true; journalctl -u "$SERVICE_NAME" "$@"; }
cmd_start()   { systemctl start "$SERVICE_NAME"; }
cmd_stop()    { systemctl stop "$SERVICE_NAME"; }
cmd_restart() { systemctl restart "$SERVICE_NAME"; }

# Restart the service and confirm it actually came up. Returns nonzero (and does
# not claim success) if the unit is not active shortly after the restart, so a
# crash-on-start is reported instead of being masked by '|| true'. A disabled-and-
# stopped autostart state is treated as "intentionally not running" -> success.
restart_service() {
    [ -f "$CONFIG" ] || [ -f "$POOL_DIR/99-overlay.json" ] || return 0   # nothing to run yet
    systemctl restart "$SERVICE_NAME" 2>/dev/null || systemctl start "$SERVICE_NAME" 2>/dev/null || true
    _i=0
    while [ "$_i" -lt 10 ]; do
        systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null && return 0
        _i=$((_i + 1)); sleep 0.3 2>/dev/null || sleep 1
    done
    # not active: only a failure if the unit is supposed to be running
    systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null && return 0
    return 1
}
# returns nonzero if the marker could not be persisted (caller must not claim success)
_save_autostart() { mkdir -p "$ETC_DIR" && printf '%s' "$1" > "$AUTOSTART_FILE"; }
cmd_enable()  { systemctl enable "$SERVICE_NAME"; _save_autostart enabled; }
cmd_disable() { systemctl disable "$SERVICE_NAME"; _save_autostart disabled; }   # autostart only; use 'stop' to stop now

cmd_config()  { [ -f "$CONFIG" ] || fatal "no config generated yet"; cat "$CONFIG"; }

cmd_set() {
    load_settings
    key="$1"; val="$2"
    # 'ping' only changes a CLI default; it never touches the xray config.
    if [ "$key" = "ping" ]; then
        case "$val" in
            get|head|tcp|icmp) PING_MODE="$val"; save_settings; c_grn "Default ping protocol = $val." ;;
            *) fatal "ping protocol must be get|head|tcp|icmp" ;;
        esac
        return
    fi
    # validate up front so a bad value is never persisted to settings.env
    case "$key" in
        port)
            case "$val" in ""|*[!0-9]*) fatal "port must be a number (1-65535)";; esac
            { [ "$val" -ge 1 ] && [ "$val" -le 65535 ]; } || fatal "port out of range (1-65535)"
            WG_PORT="$val" ;;
        mtu)
            case "$val" in ""|*[!0-9]*) fatal "mtu must be a number";; esac
            { [ "$val" -ge 576 ] && [ "$val" -le 1500 ]; } || fatal "mtu out of range (576-1500)"
            WG_MTU="$val" ;;
        keepalive)
            case "$val" in *[!0-9]*) fatal "keepalive must be a number";; esac
            WG_KEEPALIVE="${val:-0}" ;;
        dns)
            val="$(printf '%s' "$val" | tr -d ' ')"            # comma-separated, no spaces
            [ -z "$val" ] && val="8.8.8.8"                      # empty -> reset to default
            # The value is rendered into the UniFi WireGuard client's "DNS =" field,
            # which must be IP addresses (not DoH URLs / hostnames). Validate each
            # comma-separated entry as an IPv4/IPv6 literal; this also blocks any
            # shell-metachar injection (settings.env is sourced).
            py - "$val" <<'PYEOF' || fatal "DNS must be a comma-separated list of IP addresses (e.g. 8.8.8.8,1.1.1.1)"
import ipaddress, sys
items = [x for x in sys.argv[1].split(",") if x]
if not items:
    sys.exit(1)
for x in items:
    ipaddress.ip_address(x)
PYEOF
            INNER_DNS="$val" ;;
        loglevel)
            case "$val" in debug|info|warning|error|none) LOGLEVEL="$val" ;; *) fatal "loglevel must be debug|info|warning|error|none";; esac ;;
        *) fatal "unknown setting '$key' (port|mtu|dns|keepalive|loglevel|ping)" ;;
    esac
    save_settings
    if [ -f "$OUTBOUND_LINK" ] || [ -f "$POOL_SRC" ]; then
        regen_config
        if restart_service; then c_grn "Updated $key and reloaded."
        else c_ylw "Updated $key, but the service did not come up — check 'View logs'."; fi
        case "$key" in port|mtu|dns) echo; c_ylw "Update your UniFi VPN Client to match:"; cmd_wg_config ;; esac
    else
        c_grn "Updated $key (will apply when you import a link)."
    fi
    return 0
}

cmd_regen_keys() {
    load_settings
    # Rotate atomically: if a link is configured, rebuild the config with the NEW
    # keys and only keep them if that succeeds. On failure, restore the old keys so
    # the key files always match the running config (never a silent mismatch).
    if [ -f "$OUTBOUND_LINK" ]; then
        _bk="$(mktemp -d)"
        cp -p "$WG_DIR"/*.key "$_bk"/ 2>/dev/null || true
        rm -f "$WG_DIR"/*.key
        ensure_keys
        # regen_config may call fatal() (which exits); run it in a subshell so a
        # failure is caught here as a non-zero status instead of killing the CLI
        # before we can roll the keys back. On success it has already written
        # config.json (the mv inside it is atomic), so re-running it is not needed.
        if ( regen_config ) >/dev/null 2>&1; then
            rm -rf "$_bk"
            systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else
            # roll back to the previous keypair
            rm -f "$WG_DIR"/*.key
            cp -p "$_bk"/*.key "$WG_DIR"/ 2>/dev/null || true
            rm -rf "$_bk"
            fatal "key regeneration failed (config rebuild error); previous keys kept"
        fi
    else
        rm -f "$WG_DIR"/*.key
        ensure_keys
    fi
    c_ylw "New keys generated. You MUST update the UniFi VPN Client with the new config:"
    echo
    cmd_wg_config
}

cmd_update() {
    cmd_install_binary
    if restart_service; then c_grn "Updated and running."
    else c_ylw "Updated, but the service did not come back up — check 'View logs'."; fi
}

cmd_geo_update() {
    mkdir -p "$BIN_DIR"
    for f in geoip.dat geosite.dat; do
        info "downloading $f ..."
        if have curl; then
            curl -fsSL "$GEO_BASE/$f" -o "$BIN_DIR/$f.new" || { rm -f "$BIN_DIR/$f.new"; fatal "failed to fetch $f"; }
        elif have wget; then
            wget -qO "$BIN_DIR/$f.new" "$GEO_BASE/$f" || { rm -f "$BIN_DIR/$f.new"; fatal "failed to fetch $f"; }
        else
            fatal "need curl or wget to download geo files"
        fi
        mv -f "$BIN_DIR/$f.new" "$BIN_DIR/$f"
    done
    systemctl restart "$SERVICE_NAME" 2>/dev/null || true
    c_grn "Geo files updated."
}

# Print 'host<TAB>port' for the current link using the engine-appropriate generator.
_server_hp() {
    [ -f "$OUTBOUND_LINK" ] || return 1
    if [ "$(current_engine)" = "singbox" ]; then _gen="$MKSB"; else _gen="$MKCONFIG"; fi
    py "$_gen" --link "$(cat "$OUTBOUND_LINK")" --print-server 2>/dev/null
}

current_server() {
    # Pool mode has no single server: summarize the balancer instead.
    if [ "$(current_engine)" = "xraypool" ] && [ -f "$POOL_SRC" ]; then
        _pi="$(py "$MKJSON" info --profile "$POOL_SRC" 2>/dev/null)"
        _m="$(printf '%s' "$_pi" | cut -f1)"; _s="$(printf '%s' "$_pi" | cut -f2)"
        printf 'balancer pool (%s nodes, %s)\n' "${_m:-?}" "${_s:--}"
        return
    fi
    [ -f "$OUTBOUND_LINK" ] || { echo "(none imported)"; return; }
    hp="$(_server_hp)" || { echo "?"; return; }
    [ -n "$hp" ] || { echo "?"; return; }
    printf '%s:%s\n' "$(printf '%s' "$hp" | cut -f1)" "$(printf '%s' "$hp" | cut -f2)"
}

# --------------------------------------------------------------------------
# Connectivity test (`proxy ping`)
# --------------------------------------------------------------------------
_ms_from_seconds() { py -c "print('%.0f'%(float('${1:-0}')*1000))" 2>/dev/null || echo "?"; }

# ask the OS for a free loopback TCP port (avoids a fixed-port collision)
_free_port() {
    py -c 'import socket;s=socket.socket();s.bind(("127.0.0.1",0));print(s.getsockname()[1]);s.close()' 2>/dev/null \
        || echo 21080
}

_ping_cleanup() {
    [ -n "${_pid:-}" ] && { kill "$_pid" 2>/dev/null || true; wait "$_pid" 2>/dev/null || true; }
    [ -n "${_cfg:-}" ] && rm -f "$_cfg"
    _pid=""; _cfg=""
}

ping_proxy() {   # $1 = get|head
    _m="$1"; _link="$(cat "$OUTBOUND_LINK")"; _e="$(current_engine)"
    _port="$(_free_port)"
    _cfg="$(mktemp)"; _pid=""
    # ensure the spawned engine + temp config are cleaned up even on Ctrl-C / error
    trap '_ping_cleanup' EXIT INT TERM HUP
    if [ "$_e" = "singbox" ]; then
        [ -x "$SBIN" ] || { err "sing-box not installed"; _ping_cleanup; trap - EXIT INT TERM HUP; return 1; }
        py "$MKSB" --link "$_link" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { err "could not build test config"; _ping_cleanup; trap - EXIT INT TERM HUP; return 1; }
        "$SBIN" run -c "$_cfg" >/dev/null 2>&1 &
    else
        [ -x "$XRAY" ] || { err "xray binary not installed"; _ping_cleanup; trap - EXIT INT TERM HUP; return 1; }
        py "$MKCONFIG" --link "$_link" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { err "could not build test config"; _ping_cleanup; trap - EXIT INT TERM HUP; return 1; }
        # -format json: mktemp names have no extension for xray to infer the format from.
        "$XRAY" run -config "$_cfg" -format json >/dev/null 2>&1 &
    fi
    _pid=$!
    # wait (max ~4.5s) for the SOCKS listener to come up
    _i=0
    while [ "$_i" -lt 15 ]; do
        if py -c 'import socket,sys;s=socket.socket();s.settimeout(0.5)
try:
    s.connect(("127.0.0.1",'"$_port"'));s.close()
except Exception: sys.exit(1)' >/dev/null 2>&1; then break; fi
        _i=$((_i + 1)); sleep 0.3 2>/dev/null || sleep 1
    done
    if [ "$_m" = "head" ]; then _label="via proxy (HEAD)"; set -- -I; else _label="via proxy (GET)"; set -- -X GET; fi
    # LC_ALL=C so curl prints time_total with a '.' decimal regardless of locale
    _out="$(LC_ALL=C curl -sS -o /dev/null -w '%{http_code} %{time_total}' --max-time "$PING_TIMEOUT" \
             "$@" --proxy "socks5h://127.0.0.1:${_port}" "$PING_URL" 2>/dev/null)" || _out=""
    _ping_cleanup
    trap - EXIT INT TERM HUP
    if [ -z "$_out" ]; then c_red "${_label}: timeout (>${PING_TIMEOUT}s)"; return 1; fi
    _code="${_out%% *}"; _ms="$(_ms_from_seconds "${_out##* }")"
    case "$_code" in
        204|200) c_grn "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
        *)       c_ylw "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
    esac
}

ping_tcp() {
    _hp="$(_server_hp)"
    _h="$(printf '%s' "$_hp" | cut -f1)"; _p="$(printf '%s' "$_hp" | cut -f2)"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    _ms="$(py - "$_h" "$_p" "$PING_TIMEOUT" <<'PYEOF'
import socket, time, sys
host, port, timeout = sys.argv[1], int(sys.argv[2]), float(sys.argv[3])
start = time.time()
try:
    socket.create_connection((host, port), timeout=timeout).close()
    print("%.0f" % ((time.time() - start) * 1000))
except Exception:
    sys.exit(1)
PYEOF
)" || { c_red "TCP ${_h}:${_p}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    c_grn "TCP ${_h}:${_p}: ${_ms} ms"
}

ping_icmp() {
    _hp="$(_server_hp)"
    _h="$(printf '%s' "$_hp" | cut -f1)"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    # '--' so a server host starting with '-' can't be read as a ping option
    _out="$(ping -c 1 -W "$PING_TIMEOUT" -- "$_h" 2>/dev/null)" || { c_red "ICMP ${_h}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    _ms="$(printf '%s\n' "$_out" | sed -n 's/.*time=\([0-9.]*\).*/\1/p' | head -1)"
    if [ -n "$_ms" ]; then c_grn "ICMP ${_h}: ${_ms} ms"; else c_red "ICMP ${_h}: no reply (host may block ICMP)"; fi
}

cmd_ping() {
    load_settings
    if [ ! -f "$OUTBOUND_LINK" ]; then
        c_ylw "No proxy link imported. Import one first (run 'proxy' -> option 1)."
        return 1
    fi
    _mode="${1:-$PING_MODE}"
    case "$_mode" in
        get)  ping_proxy get ;;
        head) ping_proxy head ;;
        tcp)  ping_tcp ;;
        icmp) ping_icmp ;;
        *) fatal "unknown ping protocol '$_mode' (get|head|tcp|icmp)" ;;
    esac
}

