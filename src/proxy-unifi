cmd_install_binary() {
    mkdir -p "$BIN_DIR"
    slug="$(arch_slug)"
    _tag="$(resolve_latest_tag "https://github.com/XTLS/Xray-core/releases" 2>/dev/null || true)"
    _asset="Xray-linux-${slug}.zip"
    _latest="${XRAY_RELEASE_BASE}/${_asset}"
    _pinned=""
    [ -n "$_tag" ] && _pinned="https://github.com/XTLS/Xray-core/releases/download/${_tag}/${_asset}"
    ensure_run_dir
    tmp="$RUN_DIR/xray"; mkdir -p "$tmp"
    info "downloading xray-core${_tag:+ $_tag} ($slug) ..."
    download_any_to "$tmp/xray.zip" 367001600 "$_pinned" "$_latest" \
        || fatal "download failed: ${_pinned:-$_latest}"
    _xray_url="$DOWNLOAD_URL_USED"
    # D21: verify the archive against the release's published SHA-256 (.dgst). This
    # is integrity (catches corruption/truncation/MITM-without-cert), not signing.
    download_any_to "$tmp/xray.dgst" 1048576 "${_xray_url}.dgst" "${_pinned:+$_pinned.dgst}" "$_latest.dgst" 2>/dev/null \
        || fatal "xray-core checksum file is unavailable; refusing unverified update"
    _want="$(awk -F'= ' '
        tolower($1) ~ /sha2-256/ {
            value=tolower($2); gsub(/[[:space:]\r]/, "", value); print value; exit
        }' "$tmp/xray.dgst")"
    verify_sha256 "$tmp/xray.zip" "$_want" \
        || fatal "xray-core download failed mandatory checksum verification"
    info "xray-core checksum verified."
    py - "$tmp/xray.zip" "$tmp" <<'PYEOF' || fatal "could not safely extract xray.zip"
import os,stat,sys,zipfile
src,dest=sys.argv[1],os.path.realpath(sys.argv[2]); total=0; limit=350*1024*1024
with zipfile.ZipFile(src) as archive:
    infos=archive.infolist()
    for info in infos:
        target=os.path.realpath(os.path.join(dest,info.filename))
        if target!=dest and not target.startswith(dest+os.sep): raise SystemExit("unsafe zip path")
        mode=(info.external_attr >> 16) & 0xffff
        if stat.S_ISLNK(mode): raise SystemExit("zip symlinks are not allowed")
        total += max(0,info.file_size)
        if total>limit: raise SystemExit("archive is too large")
    for info in infos:
        if info.is_dir(): continue
        target=os.path.realpath(os.path.join(dest,info.filename))
        os.makedirs(os.path.dirname(target),exist_ok=True)
        with archive.open(info) as source, open(target,"wb") as output:
            while True:
                chunk=source.read(1024*1024)
                if not chunk: break
                output.write(chunk)
PYEOF
    [ -f "$tmp/xray" ] || fatal "downloaded archive did not contain an xray binary"
    chmod 0755 "$tmp/xray"
    "$tmp/xray" version >/dev/null 2>&1 || fatal "downloaded xray binary did not run"
    # D15: if a config already exists, validate it against the NEW binary before
    # switching, and keep a backup of the working binary so we can roll back.
    _had_xray=0; [ -x "$XRAY" ] && _had_xray=1
    if [ "$_had_xray" = 1 ] && { [ -f "$CONFIG" ] || [ -f "$POOL_DIR/99-overlay.json" ]; }; then
        prepare_service_permissions
        chown root:"$SERVICE_GROUP" "$RUN_DIR" "$tmp" 2>/dev/null || true
        chmod 750 "$RUN_DIR" "$tmp" 2>/dev/null || true
        if [ -f "$POOL_DIR/99-overlay.json" ]; then
            validate_as_service "$tmp/xray" run -test -confdir "$POOL_DIR" >/dev/null 2>&1 \
                || fatal "the new xray-core rejects your current profile; keeping the old version"
        elif [ -f "$CONFIG" ] && [ "$(current_engine)" = "xray" ]; then
            validate_as_service "$tmp/xray" run -test -config "$CONFIG" -format json >/dev/null 2>&1 \
                || fatal "the new xray-core rejects your current config; keeping the old version"
        fi
    fi
    if [ "$_had_xray" = 1 ]; then
        cp -p "$XRAY" "$XRAY.bak.new" || fatal "could not back up xray-core"
        mv -f "$XRAY.bak.new" "$XRAY.bak"
    fi
    install -m 0755 "$tmp/xray" "$XRAY.new" || fatal "could not stage xray binary"
    mv -f "$XRAY.new" "$XRAY" || fatal "could not install xray binary"
    if ! "$XRAY" version >/dev/null 2>&1; then
        # roll back to the previous binary
        [ -f "$XRAY.bak" ] && mv -f "$XRAY.bak" "$XRAY"
        fatal "new xray-core failed to run; rolled back to the previous version"
    fi
    # geo data ships inside the xray zip, so it refreshes on every core update.
    if [ -f "$tmp/geoip.dat" ]; then
        if ! install -m 0644 "$tmp/geoip.dat" "$BIN_DIR/geoip.dat.new" \
            || ! mv -f "$BIN_DIR/geoip.dat.new" "$BIN_DIR/geoip.dat"; then
            fatal "could not install geoip.dat"
        fi
    fi
    if [ -f "$tmp/geosite.dat" ]; then
        if ! install -m 0644 "$tmp/geosite.dat" "$BIN_DIR/geosite.dat.new" \
            || ! mv -f "$BIN_DIR/geosite.dat.new" "$BIN_DIR/geosite.dat"; then
            fatal "could not install geosite.dat"
        fi
    fi
    rm -rf "$tmp"
    c_grn "xray-core installed: $(core_version "$XRAY")"
    # sing-box (~48 MB) is only needed for ss+obfs/v2ray-plugin, hysteria2 and
    # tuic links. Don't download it eagerly: it is installed on demand the first
    # time such a link is imported (ensure_singbox). On an update, refresh it only
    # if it is already present, so xray-only installs stay lean.
    if [ -x "$SBIN" ]; then
        if ! cmd_install_singbox; then
            [ "${_STRICT_UPDATE:-0}" = 1 ] && fatal "sing-box update failed; update transaction aborted"
            c_ylw "sing-box update failed (continuing); the existing version is kept"
        fi
    else
        info "sing-box not installed (fetched automatically on the first hysteria2/tuic/ss+obfs link)."
    fi
    # The AmneziaWG-enabled core is likewise on-demand. It is a separately
    # pinned build because upstream does not publish Linux binaries for its AWG
    # endpoint branch.
    if [ -x "$ABIN" ]; then
        if ! cmd_install_awg; then
            [ "${_STRICT_UPDATE:-0}" = 1 ] && fatal "AmneziaWG core update failed; update transaction aborted"
            c_ylw "AmneziaWG core update failed (continuing); the existing version is kept"
        fi
    else
        info "AmneziaWG core not installed (fetched automatically on first profile activation)."
    fi
}

# --------------------------------------------------------------------------
# External-exposure guard for sing-box-based engines
# --------------------------------------------------------------------------
# xray binds the WireGuard inbound to 127.0.0.1 (loopback-only), so nothing it
# runs is reachable from the LAN/WAN. sing-box and amnezia-box have no
# bind-address option for their WG inbound and bind all interfaces. The local
# UniFi WG client only ever dials loopback, so we drop every NON-loopback packet
# to that UDP port, closing the external surface while leaving loopback working.
# The dedicated chain is project-owned, so cleanup never removes an
# administrator's matching rule. Protection is fail-closed before either core binds.
FW_CHAIN="PROXY_UNIFI_WG"

_ipv6_enabled() { [ -s /proc/net/if_inet6 ]; }

_fw_lock_one() {
    _ipt="$1"; _p="$2"
    "$_ipt" -N "$FW_CHAIN" 2>/dev/null || "$_ipt" -F "$FW_CHAIN" 2>/dev/null || return 1
    "$_ipt" -F "$FW_CHAIN" 2>/dev/null || return 1
    "$_ipt" -A "$FW_CHAIN" -p udp --dport "$_p" ! -i lo -j DROP 2>/dev/null || return 1
    "$_ipt" -C INPUT -j "$FW_CHAIN" 2>/dev/null \
        || "$_ipt" -I INPUT 1 -j "$FW_CHAIN" 2>/dev/null || return 1
    "$_ipt" -C INPUT -j "$FW_CHAIN" 2>/dev/null \
        && "$_ipt" -C "$FW_CHAIN" -p udp --dport "$_p" ! -i lo -j DROP 2>/dev/null
}

_fw_unlock_one() {
    _ipt="$1"; _n=0
    while [ "$_n" -lt 16 ] && "$_ipt" -C INPUT -j "$FW_CHAIN" 2>/dev/null; do
        "$_ipt" -D INPUT -j "$FW_CHAIN" 2>/dev/null || break
        _n=$((_n + 1))
    done
    "$_ipt" -F "$FW_CHAIN" 2>/dev/null || true
    "$_ipt" -X "$FW_CHAIN" 2>/dev/null || true
}

fw_lock() {
    load_settings
    have iptables || { err "iptables is required to protect sing-box's listener"; return 1; }
    _fw_lock_one iptables "$WG_PORT" || { err "could not install/verify IPv4 firewall guard"; return 1; }
    if _ipv6_enabled; then
        if ! have ip6tables || ! _fw_lock_one ip6tables "$WG_PORT"; then
            _fw_unlock_one iptables
            err "could not install/verify IPv6 firewall guard"
            return 1
        fi
    fi
}

fw_unlock() {
    for _ipt in iptables ip6tables; do
        have "$_ipt" || continue
        _fw_unlock_one "$_ipt"
    done
}

fw_is_locked() {
    _p="$1"
    have iptables && iptables -C INPUT -j "$FW_CHAIN" 2>/dev/null \
        && iptables -C "$FW_CHAIN" -p udp --dport "$_p" ! -i lo -j DROP 2>/dev/null \
        || return 1
    if _ipv6_enabled; then
        have ip6tables && ip6tables -C INPUT -j "$FW_CHAIN" 2>/dev/null \
            && ip6tables -C "$FW_CHAIN" -p udp --dport "$_p" ! -i lo -j DROP 2>/dev/null \
            || return 1
    fi
}

ensure_service_user() {
    if id "$SERVICE_USER" >/dev/null 2>&1; then
        SERVICE_GROUP="$(id -gn "$SERVICE_USER" 2>/dev/null || echo "$SERVICE_GROUP")"
        return 0
    fi
    _nologin="$(command -v nologin 2>/dev/null || echo /bin/false)"
    if have useradd; then
        useradd -r -M -d /nonexistent -s "$_nologin" "$SERVICE_USER" >/dev/null 2>&1 \
            || fatal "could not create the $SERVICE_USER service account"
    elif have adduser; then
        adduser -S -H -D -h /nonexistent -s "$_nologin" "$SERVICE_USER" >/dev/null 2>&1 \
            || fatal "could not create the $SERVICE_USER service account"
    else
        fatal "need useradd/adduser to create the unprivileged service account"
    fi
    SERVICE_GROUP="$(id -gn "$SERVICE_USER" 2>/dev/null || echo "$SERVICE_USER")"
}

prepare_service_permissions() {
    ensure_service_user
    mkdir -p "$ROOT" "$BIN_DIR" "$ETC_DIR" || fatal "could not create service directories"
    chmod 755 "$ROOT" "$BIN_DIR" || fatal "could not set service directory permissions"
    chown root:"$SERVICE_GROUP" "$ETC_DIR" \
        || fatal "could not assign service configuration group"
    chmod 750 "$ETC_DIR" || fatal "could not secure service configuration directory"
    for _readable in "$CONFIG" "$POOL_DIR"; do
        [ -e "$_readable" ] || continue
        chown -R root:"$SERVICE_GROUP" "$_readable" \
            || fatal "could not assign service-readable configuration ownership"
        if [ -d "$_readable" ]; then
            find "$_readable" -type d -exec chmod 750 {} \; \
                || fatal "could not secure service configuration directories"
            find "$_readable" -type f -exec chmod 640 {} \; \
                || fatal "could not secure service configuration files"
        else
            chmod 640 "$_readable" || fatal "could not secure service configuration file"
        fi
    done
}

validate_as_service() {
    ensure_service_user
    [ -f "$SAFEEXEC" ] || fatal "safe validator helper is missing"
    py "$SAFEEXEC" --user "$SERVICE_USER" --timeout 20 --memory-mb 256 --fsize-mb 16 -- "$@"
}

write_service() {
    prepare_service_permissions
    # ExecStart depends on the active engine. Prefer the recorded engine; if the
    # engine file was lost (e.g. after a partial restore) fall back to inferring it.
    # _fwpre/_fwpost wire the external-exposure guard to the service lifecycle:
    # for sing-box/amnezia-box, block the port BEFORE the binary binds
    # (ExecStartPre) and
    # clean up on stop; for xray (loopback-only) just clear any stale rule.
    case "$(current_engine)" in
        awg)
            _exec="$ABIN run -c $CONFIG"; _cond="$CONFIG"
            _fwpre="ExecStartPre=+$BIN_DIR/proxy-unifi _fw-lock"
            _fwpost="ExecStopPost=-+$BIN_DIR/proxy-unifi _fw-unlock" ;;
        singbox)
            _exec="$SBIN run -c $CONFIG"; _cond="$CONFIG"
            _fwpre="ExecStartPre=+$BIN_DIR/proxy-unifi _fw-lock"
            _fwpost="ExecStopPost=-+$BIN_DIR/proxy-unifi _fw-unlock" ;;
        xraypool)
            _exec="$XRAY run -confdir $POOL_DIR"; _cond="$POOL_DIR/99-overlay.json"
            _fwpre="ExecStartPre=-+$BIN_DIR/proxy-unifi _fw-unlock"; _fwpost="" ;;
        *)
            _exec="$XRAY run -config $CONFIG"; _cond="$CONFIG"
            _fwpre="ExecStartPre=-+$BIN_DIR/proxy-unifi _fw-unlock"; _fwpost="" ;;
    esac
    atomic_write "$SERVICE_FILE" 644 <<EOF || return 1
[Unit]
Description=proxy-unifi (WireGuard to proxy/VPN bridge)
After=network-online.target nss-lookup.target
Wants=network-online.target
# Don't crash-loop before a link/profile has been imported.
ConditionPathExists=$_cond

[Service]
Type=simple
User=$SERVICE_USER
Group=$SERVICE_GROUP
UMask=0077
$_fwpre
ExecStart=$_exec
$_fwpost
Environment=XRAY_LOCATION_ASSET=$BIN_DIR
WorkingDirectory=$ROOT
Restart=on-failure
RestartSec=5
LimitNOFILE=65536
LimitCORE=0
LimitFSIZE=16M
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
ProtectClock=true
ProtectHostname=true
RestrictSUIDSGID=true
LockPersonality=true
RestrictRealtime=true
MemoryDenyWriteExecute=true
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
CapabilityBoundingSet=
AmbientCapabilities=
ReadOnlyPaths=$ROOT
TasksMax=256
MemoryMax=512M
CPUQuota=200%
TimeoutStopSec=15

[Install]
WantedBy=multi-user.target
EOF
    systemctl daemon-reload 2>/dev/null || { err "systemd daemon-reload failed"; return 1; }
}

write_refresh_timer() {
    load_settings
    atomic_write "$REFRESH_SERVICE_FILE" 644 <<EOF || return 1
[Unit]
Description=Refresh proxy-unifi subscription catalog
After=network-online.target
Wants=network-online.target
ConditionPathExists=$SUB_URL_FILE

[Service]
Type=oneshot
ExecStart=$BIN_DIR/proxy-unifi sub-refresh-auto
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
EOF
    atomic_write "$REFRESH_TIMER_FILE" 644 <<EOF || return 1
[Unit]
Description=Scheduled proxy-unifi subscription refresh

[Timer]
OnBootSec=5m
OnUnitActiveSec=${SUB_REFRESH_HOURS}h
RandomizedDelaySec=5m
Persistent=true
Unit=${SERVICE_NAME}-refresh.service

[Install]
WantedBy=timers.target
EOF
    systemctl daemon-reload 2>/dev/null || return 1
}

enable_refresh_timer() {
    [ -s "$SUB_URL_FILE" ] || return 0
    write_refresh_timer || return 1
    systemctl enable --now "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1
}

disable_refresh_timer() {
    systemctl disable --now "${SERVICE_NAME}-refresh.timer" >/dev/null 2>&1 || true
}

# Remove any leftover SIP003 plugin unit from older (external-plugin) installs.
cleanup_legacy_plugin() {
    if [ -f "$PLUGIN_SERVICE_FILE" ]; then
        systemctl disable --now "$PLUGIN_SERVICE_NAME" 2>/dev/null || true
        rm -f "$PLUGIN_SERVICE_FILE"
        systemctl daemon-reload 2>/dev/null || true
    fi
}

install_service() {
    cleanup_legacy_plugin
    install_proxy_link            # safe (D20): only (re)links our own symlink
    write_service
    # Honor the user's persisted autostart choice across reboots/firmware wipes.
    # Default (no marker) = enabled, matching prior behavior.
    if [ -f "$AUTOSTART_FILE" ] && [ "$(cat "$AUTOSTART_FILE")" = "disabled" ]; then
        systemctl disable "$SERVICE_NAME" >/dev/null 2>&1 || fatal "could not disable service autostart"
    else
        systemctl enable "$SERVICE_NAME" >/dev/null 2>&1 || fatal "could not enable service autostart"
    fi
    if [ -s "$SUB_URL_FILE" ]; then
        enable_refresh_timer || fatal "could not enable subscription refresh timer"
    else
        write_refresh_timer || true
    fi
}

boot_recover() {
    install_service
    if { [ -f "$CONFIG" ] || [ -f "$POOL_DIR/99-overlay.json" ]; } \
        && [ "$(cat "$AUTOSTART_FILE" 2>/dev/null || echo enabled)" != "disabled" ]; then
        restart_service || fatal "service failed its boot recovery health check"
    fi
}

# Build + validate from a mode-600 candidate link file. No proxy credential or
# WireGuard key is ever placed in argv/environment.
_build_config_file() {
    _link_file="$1"
    ensure_keys
    _eng="$(engine_for_link_file "$_link_file")"
    [ -n "$_eng" ] || fatal "unsupported link (expected vless/vmess/trojan/ss/hysteria2/tuic)"
    if [ "$_eng" = "singbox" ] && [ "$WG_LISTEN" != "127.0.0.1" ]; then
        fatal "sing-box cannot bind its WireGuard endpoint to WG_LISTEN=$WG_LISTEN; use 127.0.0.1"
    fi
    mkdir -p "$ETC_DIR" || fatal "could not create $ETC_DIR"
    prepare_service_permissions
    tmpcfg="$(mktemp "$ETC_DIR/.cfg.XXXXXX")" || fatal "could not create temp file"
    if [ "$_eng" = "singbox" ]; then
        ensure_singbox
        py "$MKSB" --link-file "$_link_file" \
            --secret-key-file "$WG_DIR/wg_private.key" \
            --peer-pubkey-file "$WG_DIR/unifi_public.key" --port "$WG_PORT" \
            --address "$XRAY_ADDR" --mtu "$WG_MTU" --loglevel "$(sb_loglevel)" \
            > "$tmpcfg" || fatal "config generation failed (check the link)"
        if [ -x "$SBIN" ]; then
            chown root:"$SERVICE_GROUP" "$tmpcfg"; chmod 640 "$tmpcfg"
            validate_as_service "$SBIN" check -c "$tmpcfg" >/dev/null 2>&1 \
                || fatal "sing-box rejected the generated config"
        fi
    else
        set --
        [ -n "$INNER_DNS" ] && set -- --dns "$INNER_DNS"
        py "$MKXRAY" --link-file "$_link_file" \
            --secret-key-file "$WG_DIR/wg_private.key" \
            --peer-pubkey-file "$WG_DIR/unifi_public.key" \
            --listen "$WG_LISTEN" --port "$WG_PORT" \
            --address "$XRAY_ADDR" --mtu "$WG_MTU" \
            --keepalive "$WG_KEEPALIVE" --loglevel "$LOGLEVEL" \
            "$@" \
            > "$tmpcfg" || fatal "config generation failed (check the link)"
        # -format json is required because xray infers format from the extension.
        if [ -x "$XRAY" ]; then
            chown root:"$SERVICE_GROUP" "$tmpcfg"; chmod 640 "$tmpcfg"
            validate_as_service "$XRAY" run -test -config "$tmpcfg" -format json >/dev/null 2>&1 \
                || fatal "xray rejected the generated config (-test failed)"
        fi
    fi
    [ -s "$tmpcfg" ] || fatal "generated config is empty"
    mv -f "$tmpcfg" "$CONFIG" || fatal "could not install config"
    chown root:"$SERVICE_GROUP" "$CONFIG"; chmod 640 "$CONFIG"
    printf '%s' "$_eng" | atomic_write "$ENGINE_FILE" 600 || fatal "could not write engine marker"
    rm -f "$SERVER_CACHE" 2>/dev/null || true   # server changed -> drop the menu cache
    # Refresh the systemd unit so ExecStart matches the (possibly changed) engine.
    if [ -f "$SERVICE_FILE" ]; then
        write_service || fatal "could not update the systemd service"
    fi
}

awg_selected_profile() {
    _asp_id="$(cat "$AWG_SELECTED" 2>/dev/null || true)"
    case "$_asp_id" in
        ????????-????-????-????-????????????) : ;;
        *) return 1 ;;
    esac
    case "$_asp_id" in *[!0-9a-f-]*) return 1 ;; esac
    _asp_path="$AWG_PROFILES_DIR/${_asp_id}.conf"
    [ -f "$_asp_path" ] && [ ! -L "$_asp_path" ] || return 1
    printf '%s\n' "$_asp_path"
}

_build_awg_profile() {
    _ap="$1"
    [ -s "$_ap" ] || fatal "AmneziaWG profile is empty or missing"
    [ "$WG_LISTEN" = "127.0.0.1" ] \
        || fatal "the AmneziaWG core cannot bind its inner WireGuard endpoint to WG_LISTEN=$WG_LISTEN; use 127.0.0.1"
    [ -f "$MKAWG" ] || fatal "AmneziaWG profile helper is missing"
    ensure_awg
    ensure_keys
    mkdir -p "$ETC_DIR" || fatal "could not create $ETC_DIR"
    prepare_service_permissions
    _tmpcfg="$(mktemp "$ETC_DIR/.awgcfg.XXXXXX")" || fatal "could not create temporary config"
    py "$MKAWG" build --file "$_ap" \
        --secret-key-file "$WG_DIR/wg_private.key" \
        --peer-pubkey-file "$WG_DIR/unifi_public.key" \
        --port "$WG_PORT" --address "$XRAY_ADDR" --mtu "$WG_MTU" \
        --loglevel "$(sb_loglevel)" > "$_tmpcfg" \
        || fatal "AmneziaWG config generation failed"
    [ -s "$_tmpcfg" ] || fatal "generated AmneziaWG config is empty"
    chown root:"$SERVICE_GROUP" "$_tmpcfg"; chmod 640 "$_tmpcfg"
    validate_as_service "$ABIN" check -c "$_tmpcfg" >/dev/null 2>&1 \
        || fatal "the AmneziaWG core rejected this profile"
    mv -f "$_tmpcfg" "$CONFIG" || fatal "could not install AmneziaWG config"
    chown root:"$SERVICE_GROUP" "$CONFIG"; chmod 640 "$CONFIG"
    printf 'awg' | atomic_write "$ENGINE_FILE" 600 || fatal "could not write engine marker"
    rm -f "$SERVER_CACHE" 2>/dev/null || true
    if [ -f "$SERVICE_FILE" ]; then
        write_service || fatal "could not update the systemd service"
    fi
}

regen_config() {
    if [ "$(current_engine)" = "awg" ]; then
        _active_awg="$(awg_selected_profile)" \
            || fatal "the selected AmneziaWG profile is missing or invalid"
        _build_awg_profile "$_active_awg"
    elif [ -f "$POOL_SRC" ] && [ "$(current_engine)" = "xraypool" ]; then
        _build_pool "$POOL_SRC"
    else
        [ -f "$OUTBOUND_LINK" ] || fatal "no proxy link imported yet. Run 'proxy' and choose option 1."
        _build_config_file "$OUTBOUND_LINK"
    fi
}

# Build + validate an Xray JSON *profile* (balancer/pool) into the -confdir POOL_DIR.
# The raw provider source is retained separately for audit/refresh identity. The
# executable projection is validated/sanitized, and a WG inbound overlay replaces
# its local entry by tag. State is swapped only after a clean core validation.
_build_pool() {
    _pf="$1"
    [ -x "$XRAY" ] || fatal "xray-core is required for JSON balancer profiles"
    ensure_keys
    mkdir -p "$ETC_DIR" || fatal "could not create $ETC_DIR"
    _stage="$(mktemp -d "$ETC_DIR/.pool.XXXXXX")" || fatal "could not create temp dir"
    prepare_service_permissions
    chown root:"$SERVICE_GROUP" "$_stage"; chmod 750 "$_stage"
    py "$MKJSON" overlay --profile "$_pf" \
        --out-provider "$_stage/01-provider.json" \
        --out-overlay "$_stage/99-overlay.json" \
        --listen "$WG_LISTEN" --port "$WG_PORT" \
        --secret-key-file "$WG_DIR/wg_private.key" \
        --peer-pubkey-file "$WG_DIR/unifi_public.key" \
        --address "$XRAY_ADDR" --mtu "$WG_MTU" --keepalive "$WG_KEEPALIVE" --loglevel "$LOGLEVEL" \
        >/dev/null || fatal "could not build pool profile (unsupported or invalid JSON)"
    chown root:"$SERVICE_GROUP" "$_stage"/*.json; chmod 640 "$_stage"/*.json
    validate_as_service "$XRAY" run -test -confdir "$_stage" >/dev/null 2>&1 \
        || fatal "xray rejected the pool profile (-test failed)"
    ensure_run_dir
    _old_pool="$RUN_DIR/pool.old"
    rm -rf "$_old_pool"
    [ -d "$POOL_DIR" ] && mv "$POOL_DIR" "$_old_pool"
    mv "$_stage" "$POOL_DIR" || { [ -d "$_old_pool" ] && mv "$_old_pool" "$POOL_DIR"; fatal "could not install pool dir"; }
    rm -rf "$_old_pool"
    printf 'xraypool' | atomic_write "$ENGINE_FILE" 600 || fatal "could not write engine marker"
    rm -f "$SERVER_CACHE" 2>/dev/null || true   # server changed -> drop the menu cache
    # pool mode has no single config.json; clear a stale one so status is accurate
    rm -f "$CONFIG" 2>/dev/null || true
    if [ -f "$SERVICE_FILE" ]; then
        write_service || fatal "could not update the systemd service"
    fi
}

# Import a JSON balancer/pool profile from a file (or piped content already saved
# to a temp file). $1 = path to the provider JSON.
cmd_import_json() {
    _src="$1"
    [ -s "$_src" ] || fatal "empty profile"
    load_settings
    _cmd_owned=0
    if [ -z "$TXN_DIR" ]; then txn_begin; _cmd_owned=1; fi
    # build first; only commit POOL_SRC on success (never clobber a working setup)
    _build_pool "$_src"
    atomic_write "$POOL_SRC" 600 < "$_src" || fatal "could not store profile"
    # a pool import supersedes any single link + subscription selection
    rm -f "$OUTBOUND_LINK" 2>/dev/null || true
    rm -f "$AWG_SELECTED" 2>/dev/null || true
    [ "${_FROM_SUB:-0}" = "1" ] || rm -f "$SUB_SELECTED" "$SUB_SELECTED_META" 2>/dev/null || true
    save_settings
    restart_service || fatal "profile was valid, but the service failed its startup health check"
    [ "$_cmd_owned" = 1 ] && txn_commit
    if [ "${_QUIET:-0}" != 1 ]; then
        c_grn "Imported balancer profile and applied."
        echo
        cmd_wg_config
    fi
}

cmd_import() {
    [ $# -ge 1 ] || fatal "usage: proxy import <vless:// | vmess:// | trojan:// | ss:// | hysteria2:// | tuic:// ...>"
    link="$1"
    case "$link" in
        vless://*|vmess://*|trojan://*|ss://*|hysteria2://*|hy2://*|tuic://*) : ;;
        *) fatal "unsupported link (expected vless://, vmess://, trojan://, ss://, hysteria2:// or tuic://)" ;;
    esac
    _bytes="$(LC_ALL=C printf '%s' "$link" | wc -c | tr -d ' ')"
    [ "$_bytes" -le 8000 ] || fatal "proxy link is too long (maximum 8000 bytes)"
    if LC_ALL=C printf '%s' "$link" | grep -q '[[:cntrl:]]'; then
        fatal "proxy link contains control characters"
    fi
    load_settings
    _cmd_owned=0
    if [ -z "$TXN_DIR" ]; then txn_begin; _cmd_owned=1; fi
    ensure_run_dir
    _candidate_link="$RUN_DIR/link.candidate"
    printf '%s' "$link" | atomic_write "$_candidate_link" 600 || fatal "could not stage proxy link"
    _build_config_file "$_candidate_link"
    atomic_write "$OUTBOUND_LINK" 600 < "$_candidate_link" || fatal "could not store proxy link"
    # a single-link import supersedes any active pool profile
    rm -rf "$POOL_DIR" "$POOL_SRC" 2>/dev/null || true
    rm -f "$AWG_SELECTED" 2>/dev/null || true
    save_settings
    # A manual import detaches any subscription selection (so a later 'sub refresh'
    # won't think this hand-picked link came from the subscription). sub_select sets
    # _FROM_SUB=1 to keep its own marker.
    [ "${_FROM_SUB:-0}" = "1" ] || rm -f "$SUB_SELECTED" "$SUB_SELECTED_META" 2>/dev/null || true
    # Apply immediately (starts the service even if autostart is off; the unit's
    # ConditionPathExists is now satisfied because config.json exists).
    restart_service || fatal "link was valid, but the service failed its startup health check"
    [ "$_cmd_owned" = 1 ] && txn_commit
    if [ "${_QUIET:-0}" != 1 ]; then
        c_grn "Imported and applied."
        echo
        cmd_wg_config
    fi
}

cmd_wg_config() {
    [ -f "$WG_DIR/unifi_private.key" ] || fatal "no keys yet. Import a proxy or activate an AmneziaWG profile first."
    load_settings
    upriv="$(cat "$WG_DIR/unifi_private.key")"
    xpub="$(cat "$WG_DIR/wg_public.key")"
    endpoint="$(wg_endpoint)"
    c_bold "================  UniFi WireGuard VPN Client  ================"
    echo
    echo "In unifi.ui.com: Settings -> VPN -> VPN Client -> Create New (WireGuard)."
    echo "Either enter these manually, or upload the .conf below:"
    echo
    printf '%-19s %s\n' "Private Key:"        "$upriv"
    printf '%-19s %s\n' "Public Key (peer):"  "$xpub"
    printf '%-19s %s\n' "Endpoint:"           "$endpoint"
    printf '%-19s %s\n' "Pre-shared Key:"     "(leave empty)"
    printf '%-19s %s\n' "Address/Local IP:"   "$UNIFI_ADDR"
    printf '%-19s %s\n' "Allowed IPs:"        "0.0.0.0/0, ::/0"
    printf '%-19s %s\n' "MTU:"                "$WG_MTU"
    [ -n "$INNER_DNS" ] && printf '%-19s %s\n' "DNS:" "$INNER_DNS"
    echo
    c_ylw "Save this as a .conf and use 'Upload Configuration File':"
    echo "----------------------------------------------------------------"
    cat <<EOF
[Interface]
PrivateKey = $upriv
Address = $UNIFI_ADDR
$( [ -n "$INNER_DNS" ] && echo "DNS = $INNER_DNS" )
MTU = $WG_MTU

[Peer]
PublicKey = $xpub
Endpoint = $endpoint
AllowedIPs = 0.0.0.0/0, ::/0
PersistentKeepalive = $WG_KEEPALIVE
EOF
    echo "----------------------------------------------------------------"
    echo
    echo "After it connects, go to Policy Engine -> Policy Table and create a"
    echo "Traffic Route that sends your chosen VLAN/clients through this VPN Client."
    c_bold "============================================================="
}

cmd_status() {
    load_settings
    act="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null || true)"
    ena="$(systemctl is-enabled "$SERVICE_NAME" 2>/dev/null || true)"
    echo "service:   ${act:-unknown} / ${ena:-disabled}"
    _eng="$(current_engine)"
    echo "engine:    $_eng"
    if [ "$_eng" = "awg" ]; then
        if [ -x "$ABIN" ]; then echo "core:      $(core_version "$ABIN")"; else echo "core:      AmneziaWG core not installed"; fi
    elif [ "$_eng" = "singbox" ]; then
        if [ -x "$SBIN" ]; then echo "core:      $(core_version "$SBIN")"; else echo "core:      sing-box not installed"; fi
    else
        if [ -x "$XRAY" ]; then echo "core:      $(core_version "$XRAY")"; else echo "core:      xray not installed"; fi
    fi
    echo "server:    $(current_server)"
    # The sing-box-based cores bind the WG port on all interfaces; a firewall
    # rule blocks non-loopback access. Report the protection actually in effect.
    if [ "$_eng" = "singbox" ] || [ "$_eng" = "awg" ]; then
        if fw_is_locked "$WG_PORT"; then
            echo "wg listen: 0.0.0.0:${WG_PORT} (loopback only; LAN/WAN blocked by firewall)  mtu=${WG_MTU}"
        else
            c_ylw "wg listen: 0.0.0.0:${WG_PORT} (all interfaces; firewall rule NOT active)  mtu=${WG_MTU}"
        fi
    else
        echo "wg listen: $(wg_endpoint)  mtu=${WG_MTU}"
    fi
    if have ss; then
        if socket_listening "$WG_PORT"; then c_grn "udp/${WG_PORT}: listening"; else c_ylw "udp/${WG_PORT}: not listening"; fi
    fi
}

cmd_logs()    { shift || true; journalctl -u "$SERVICE_NAME" "$@"; }
cmd_start()   { systemctl start "$SERVICE_NAME"; }
cmd_stop()    { systemctl stop "$SERVICE_NAME"; }
cmd_restart() { systemctl restart "$SERVICE_NAME"; }

# Restart the service and confirm it actually came up. Returns nonzero (and does
# not claim success) if the unit is not active shortly after the restart, so a
# crash-on-start is reported instead of being masked by '|| true'. A disabled-and-
# stopped autostart state is treated as "intentionally not running" -> success.
_socket_listening() {
    have ss || return 1
    _ss_flags="$1"; _ss_port="$2"
    ss "$_ss_flags" 2>/dev/null | awk -v port="$_ss_port" '
        NR > 1 {
            if ($0 ~ (":" port "([[:space:]]|$)")) found=1
        }
        END { exit(found ? 0 : 1) }'
}
socket_listening() { _socket_listening -lun "$1"; }
tcp_socket_listening() { _socket_listening -ltn "$1"; }

socket_owned_by_pid() {
    _port="$1"; _pid="$2"
    have ss || return 1
    ss -lunp 2>/dev/null | awk -v port="$_port" -v pid="$_pid" '
            $0 ~ (":" port "([[:space:]]|$)") && $0 ~ ("pid=" pid "([,)]|$)") { found=1 }
            END { exit(found ? 0 : 1) }'
}

service_healthy() {
    _unit_state="$(systemctl show -p ActiveState -p MainPID "$SERVICE_NAME" 2>/dev/null)" || return 1
    case "$_unit_state" in *'ActiveState=active'*) : ;; *) return 1 ;; esac
    _main_pid="${_unit_state#*MainPID=}"
    _main_pid="${_main_pid%%[!0-9]*}"
    case "$_main_pid" in ""|0|*[!0-9]*) return 1 ;; esac
    kill -0 "$_main_pid" 2>/dev/null || return 1
    socket_owned_by_pid "$WG_PORT" "$_main_pid"
}

restart_service() {
    [ -f "$CONFIG" ] || [ -f "$POOL_DIR/99-overlay.json" ] || return 0   # nothing to run yet
    systemctl restart "$SERVICE_NAME" 2>/dev/null || systemctl start "$SERVICE_NAME" 2>/dev/null || return 1
    _i=0
    _stable=0
    while [ "$_i" -lt 40 ]; do
        if service_healthy; then
            _stable=$((_stable + 1))
            [ "$_stable" -ge 8 ] && return 0
        else
            _stable=0
        fi
        _i=$((_i + 1)); sleep 0.25 2>/dev/null || sleep 1
    done
    return 1
}

restart_if_previously_active() {
    if [ -n "$TXN_DIR" ] && [ ! -f "$TXN_DIR/service-active" ]; then
        return 0
    fi
    restart_service
}
# returns nonzero if the marker could not be persisted (caller must not claim success)
_save_autostart() { mkdir -p "$ETC_DIR" && printf '%s' "$1" | atomic_write "$AUTOSTART_FILE" 600; }

cmd_config()  {
    # A balancer/pool profile runs from a -confdir, not a single config.json;
    # show the confdir parts so this works in pool mode too.
    if [ "$(current_engine)" = "xraypool" ] && [ -d "$POOL_DIR" ]; then
        for _f in "$POOL_DIR"/*.json; do
            [ -f "$_f" ] || continue
            printf '===== %s =====\n' "$(basename "$_f")"; cat "$_f"; printf '\n'
        done
        return
    fi
    if [ "$(current_engine)" = "awg" ]; then
        awg_details
        return
    fi
    [ -f "$CONFIG" ] || fatal "no config generated yet"; cat "$CONFIG"
}

cmd_set() {
    load_settings
    key="$1"; val="$2"
    _cmd_owned=0
    if [ -z "$TXN_DIR" ]; then txn_begin; _cmd_owned=1; fi
    # 'ping' only changes a CLI default; it never touches the xray config.
    if [ "$key" = "ping" ]; then
        case "$val" in
            get|head|tcp|icmp) PING_MODE="$val"; save_settings; [ "$_cmd_owned" = 1 ] && txn_commit; c_grn "Default ping protocol = $val." ;;
            *) fatal "ping protocol must be get|head|tcp|icmp" ;;
        esac
        return
    fi
    # validate up front so a bad value is never persisted to settings.env
    case "$key" in
        port)
            case "$val" in ""|*[!0-9]*) fatal "port must be a number (1-65535)";; esac
            { [ "$val" -ge 1 ] && [ "$val" -le 65535 ]; } || fatal "port out of range (1-65535)"
            WG_PORT="$val" ;;
        mtu)
            case "$val" in ""|*[!0-9]*) fatal "mtu must be a number";; esac
            { [ "$val" -ge 576 ] && [ "$val" -le 1500 ]; } || fatal "mtu out of range (576-1500)"
            WG_MTU="$val" ;;
        keepalive)
            case "$val" in *[!0-9]*) fatal "keepalive must be a number";; esac
            WG_KEEPALIVE="${val:-0}" ;;
        dns)
            val="$(printf '%s' "$val" | tr -d ' ')"            # comma-separated, no spaces
            [ -z "$val" ] && val="8.8.8.8"                      # empty -> reset to default
            # The value is rendered into the UniFi WireGuard client's "DNS =" field,
            # which must be IP addresses (not DoH URLs / hostnames). Validate each
            # comma-separated entry as an IPv4/IPv6 literal; this also blocks any
            # shell-metachar/control-byte injection before settings.env is rendered.
            py - "$val" <<'PYEOF' || fatal "DNS must be a comma-separated list of IP addresses (e.g. 8.8.8.8,1.1.1.1)"
import ipaddress, sys
items = [x for x in sys.argv[1].split(",") if x]
if not items:
    sys.exit(1)
for x in items:
    ipaddress.ip_address(x)
PYEOF
            INNER_DNS="$val" ;;
        loglevel)
            case "$val" in debug|info|warning|error|none) LOGLEVEL="$val" ;; *) fatal "loglevel must be debug|info|warning|error|none";; esac ;;
        *) fatal "unknown setting '$key' (port|mtu|dns|keepalive|loglevel|ping)" ;;
    esac
    save_settings
    if [ -f "$OUTBOUND_LINK" ] || [ -f "$POOL_SRC" ] || [ -s "$AWG_SELECTED" ]; then
        regen_config
        restart_if_previously_active || fatal "updated config failed its startup health check; previous settings restored"
        [ "$_cmd_owned" = 1 ] && txn_commit
        c_grn "Updated $key and reloaded."
        case "$key" in port|mtu|dns) echo; c_ylw "Update your UniFi VPN Client to match:"; cmd_wg_config ;; esac
    else
        [ "$_cmd_owned" = 1 ] && txn_commit
        c_grn "Updated $key (will apply when you import a link)."
    fi
    return 0
}

cmd_regen_keys() {
    load_settings
    txn_begin
    rm -f "$WG_DIR"/*.key
    ensure_keys
    if [ -f "$OUTBOUND_LINK" ] || [ -f "$POOL_SRC" ] || [ -s "$AWG_SELECTED" ]; then
        regen_config
        restart_if_previously_active || fatal "new-key config failed its startup health check; previous keys restored"
    fi
    txn_commit
    c_ylw "New keys generated. You MUST update the UniFi VPN Client with the new config:"
    echo
    cmd_wg_config
}

cmd_update() {
    ensure_run_dir
    _update_was_active=0
    systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null && _update_was_active=1
    UPDATE_WAS_ACTIVE="$_update_was_active"
    _backup="$RUN_DIR/update-backup"; mkdir -p "$_backup"
    for _name in xray sing-box amnezia-box geoip.dat geosite.dat; do
        if [ -e "$BIN_DIR/$_name" ]; then cp -p "$BIN_DIR/$_name" "$_backup/$_name" || fatal "could not back up $_name"
        else : > "$_backup/$_name.absent"; fi
    done
    UPDATE_BACKUP="$_backup"
    if ! ( _STRICT_UPDATE=1; cmd_install_binary ); then
        _restore_update_backup "$_backup" || fatal "core update failed and the previous binaries/assets could not be fully restored"
        UPDATE_BACKUP=""
        fatal "core update failed; previous binaries/assets restored"
    fi
    if ! ( write_service ); then
        _restore_update_backup "$_backup" || fatal "service regeneration failed and core rollback was incomplete"
        UPDATE_BACKUP=""
        ( write_service ) 2>/dev/null || true
        if [ "$_update_was_active" = 1 ]; then systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else systemctl stop "$SERVICE_NAME" 2>/dev/null || true; fi
        fatal "service regeneration failed; previous binaries/assets restored"
    fi
    if [ "$_update_was_active" = 1 ] && ! restart_service; then
        _restore_update_backup "$_backup" || fatal "updated core failed and binary rollback was incomplete"
        UPDATE_BACKUP=""
        ( write_service ) || true
        if [ "$_update_was_active" = 1 ]; then systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        else systemctl stop "$SERVICE_NAME" 2>/dev/null || true; fi
        fatal "updated core failed runtime health checks; rolled back"
    fi
    UPDATE_BACKUP=""
    if [ "$_update_was_active" = 1 ]; then c_grn "Updated and running."
    else c_grn "Updated. Service remains stopped."; fi
}

_restore_update_backup() {
    _backup="$1"
    _restore_rc=0
    for _name in xray sing-box amnezia-box geoip.dat geosite.dat; do
        if [ -f "$_backup/$_name.absent" ]; then rm -f "$BIN_DIR/$_name" || _restore_rc=1
        elif [ -f "$_backup/$_name" ]; then
            install -m "$( [ -x "$_backup/$_name" ] && echo 0755 || echo 0644 )" \
                "$_backup/$_name" "$BIN_DIR/$_name" || _restore_rc=1
        fi
    done
    return "$_restore_rc"
}

cmd_geo_update() {
    mkdir -p "$BIN_DIR"
    ensure_run_dir
    _tag="$(resolve_latest_tag "https://github.com/Loyalsoldier/v2ray-rules-dat/releases")"
    [ -n "$_tag" ] || fatal "could not resolve geo-data release"
    _backup="$RUN_DIR/geo-backup"; mkdir -p "$_backup"
    _geo_was_active=0
    systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null && _geo_was_active=1
    GEO_WAS_ACTIVE="$_geo_was_active"
    for f in geoip.dat geosite.dat; do
        if [ -f "$BIN_DIR/$f" ]; then
            cp -p "$BIN_DIR/$f" "$_backup/$f" || fatal "could not back up $f"
        else
            : > "$_backup/$f.absent"
        fi
        GEO_BACKUP="$_backup"
        info "downloading $f ..."
        download_to "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/download/${_tag}/$f" "$BIN_DIR/$f.new" 209715200 \
            || { rm -f "$BIN_DIR/$f.new"; _restore_geo_backup "$_backup" || fatal "download failed and geo rollback was incomplete"; GEO_BACKUP=""; fatal "failed to fetch $f"; }
        _want="$(github_asset_digest Loyalsoldier/v2ray-rules-dat "$_tag" "$f" 2>/dev/null)" \
            || { rm -f "$BIN_DIR/$f.new"; _restore_geo_backup "$_backup" || fatal "digest lookup failed and geo rollback was incomplete"; GEO_BACKUP=""; fatal "could not obtain digest for $f"; }
        verify_sha256 "$BIN_DIR/$f.new" "$_want" \
            || { rm -f "$BIN_DIR/$f.new"; _restore_geo_backup "$_backup" || fatal "checksum failed and geo rollback was incomplete"; GEO_BACKUP=""; fatal "checksum failed for $f"; }
        mv -f "$BIN_DIR/$f.new" "$BIN_DIR/$f"
    done
    if [ "$_geo_was_active" = 1 ] && ! restart_service; then
        _restore_geo_backup "$_backup" || fatal "geo runtime check failed and rollback was incomplete"
        GEO_BACKUP=""
        systemctl restart "$SERVICE_NAME" 2>/dev/null || true
        fatal "geo update failed runtime health checks; rolled back"
    fi
    GEO_BACKUP=""
    if [ "$_geo_was_active" = 1 ]; then c_grn "Geo files updated and service restarted."
    else c_grn "Geo files updated. Service remains stopped."; fi
}

_restore_geo_backup() {
    _backup="$1"
    _restore_rc=0
    for _name in geoip.dat geosite.dat; do
        if [ -f "$_backup/$_name.absent" ]; then rm -f "$BIN_DIR/$_name" || _restore_rc=1
        elif [ -f "$_backup/$_name" ]; then install -m 0644 "$_backup/$_name" "$BIN_DIR/$_name" || _restore_rc=1
        fi
    done
    return "$_restore_rc"
}

# Print 'host<TAB>port' for the current link using the engine-appropriate generator.
_server_hp() {
    if [ "$(current_engine)" = "awg" ]; then
        _awg_profile="$(awg_selected_profile)" || return 1
        py "$MKAWG" server --file "$_awg_profile" 2>/dev/null
        return
    fi
    [ -f "$OUTBOUND_LINK" ] || return 1
    if [ "$(current_engine)" = "singbox" ]; then _gen="$MKSB"; else _gen="$MKXRAY"; fi
    py "$_gen" --link-file "$OUTBOUND_LINK" --print-server 2>/dev/null
}

# Cached for menu speed: computing the server string spawns python (link parse
# or balancer info), which is wasteful on every menu redraw. The value only
# changes when the config does, so cache it and let _build_config/_build_pool
# invalidate (rm) the cache. A cache miss recomputes once and re-populates it.
current_server() {
    if [ -s "$SERVER_CACHE" ]; then cat "$SERVER_CACHE"; return; fi
    _cs="$(_compute_server)"
    # Cache only once $ETC_DIR exists (it does not before the first import), and
    # put 2>/dev/null BEFORE '>' so a failed open can't leak a shell redirection
    # error onto the menu.
    if [ -d "$ETC_DIR" ]; then printf '%s' "$_cs" | atomic_write "$SERVER_CACHE" 600 2>/dev/null || true; fi
    printf '%s\n' "$_cs"
}
_compute_server() {
    # Pool mode has no single server: summarize the balancer instead.
    if [ "$(current_engine)" = "xraypool" ] && [ -f "$POOL_SRC" ]; then
        _pi="$(py "$MKJSON" info --profile "$POOL_SRC" 2>/dev/null)"
        _m="${_pi%%"$TAB"*}"
        _rest="${_pi#*"$TAB"}"
        _s="${_rest%%"$TAB"*}"
        printf 'balancer pool (%s nodes, %s)' "${_m:-?}" "${_s:--}"
        return
    fi
    if [ "$(current_engine)" = "awg" ]; then
        _awg_path="$(awg_selected_profile)" || { printf 'AmneziaWG (selected profile missing)'; return; }
        hp="$(py "$MKAWG" server --file "$_awg_path" 2>/dev/null)" \
            || { printf 'AmneziaWG (invalid selected profile)'; return; }
        _host="${hp%%"$TAB"*}"; _port="${hp#*"$TAB"}"
        printf 'AWG %s' "$(format_endpoint "$_host" "$_port")"
        return
    fi
    [ -f "$OUTBOUND_LINK" ] || { printf '(none imported)'; return; }
    hp="$(_server_hp)" || { printf '?'; return; }
    [ -n "$hp" ] || { printf '?'; return; }
    _host="${hp%%"$TAB"*}"
    _port="${hp#*"$TAB"}"
    format_endpoint "$_host" "$_port"
}

# --------------------------------------------------------------------------
# Connectivity test (`proxy ping`)
# --------------------------------------------------------------------------
_ms_from_seconds() {
    LC_ALL=C awk -v seconds="${1:-0}" 'BEGIN { printf "%.0f", seconds * 1000 }' 2>/dev/null || echo "?"
}

# ask the OS for a free loopback TCP port (avoids a fixed-port collision)
_free_port() {
    py -c 'import socket;s=socket.socket();s.bind(("127.0.0.1",0));print(s.getsockname()[1]);s.close()' 2>/dev/null \
        || echo 21080
}

_ping_cleanup() {
    [ -n "${_pid:-}" ] && { kill "$_pid" 2>/dev/null || true; wait "$_pid" 2>/dev/null || true; }
    [ -n "${_cfg:-}" ] && rm -f "$_cfg"
    _pid=""; _cfg=""; BG_PID=""
}

ping_proxy() {   # $1 = get|head
    have curl || { err "curl is required for proxy HTTP latency tests"; return 1; }
    _m="$1"; _e="$(current_engine)"
    _port="$(_free_port)"
    ensure_run_dir
    _cfg="$RUN_DIR/ping.json"; _pid=""
    if [ "$_e" = "xraypool" ]; then
        # balancer/pool: expose the provider's outbounds through a local SOCKS
        # inbound so we measure latency through the same balancer xray uses live.
        [ -x "$XRAY" ] || { err "xray binary not installed"; _ping_cleanup; return 1; }
        [ -f "$POOL_SRC" ] || { err "no pool profile on disk"; _ping_cleanup; return 1; }
        py "$MKJSON" socksconfig --profile "$POOL_SRC" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { err "could not build test config"; _ping_cleanup; return 1; }
        set -- "$XRAY" run -config "$_cfg" -format json
    elif [ "$_e" = "awg" ]; then
        [ -x "$ABIN" ] || { err "AmneziaWG core not installed"; _ping_cleanup; return 1; }
        _awg_profile="$(awg_selected_profile)" \
            || { err "selected AmneziaWG profile is missing"; _ping_cleanup; return 1; }
        py "$MKAWG" build --file "$_awg_profile" --socks-port "$_port" \
            --loglevel "$(sb_loglevel)" > "$_cfg" 2>/dev/null \
            || { err "could not build AmneziaWG test config"; _ping_cleanup; return 1; }
        set -- "$ABIN" run -c "$_cfg"
    elif [ "$_e" = "singbox" ]; then
        [ -x "$SBIN" ] || { err "sing-box not installed"; _ping_cleanup; return 1; }
        py "$MKSB" --link-file "$OUTBOUND_LINK" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { err "could not build test config"; _ping_cleanup; return 1; }
        set -- "$SBIN" run -c "$_cfg"
    else
        [ -x "$XRAY" ] || { err "xray binary not installed"; _ping_cleanup; return 1; }
        py "$MKXRAY" --link-file "$OUTBOUND_LINK" --socks-port "$_port" > "$_cfg" 2>/dev/null \
            || { err "could not build test config"; _ping_cleanup; return 1; }
        set -- "$XRAY" run -config "$_cfg" -format json
    fi
    ensure_service_user
    chown root:"$SERVICE_GROUP" "$RUN_DIR" "$_cfg"; chmod 750 "$RUN_DIR"; chmod 640 "$_cfg"
    _ping_budget=$((PING_TIMEOUT + 15))
    py "$SAFEEXEC" --user "$SERVICE_USER" --timeout "$_ping_budget" --memory-mb 256 --fsize-mb 16 -- "$@" >/dev/null 2>&1 &
    _pid=$!; BG_PID="$_pid"
    # wait (max ~4.5s) for the SOCKS listener to come up
    _i=0
    while [ "$_i" -lt 15 ]; do
        if tcp_socket_listening "$_port"; then break; fi
        _i=$((_i + 1)); sleep 0.3 2>/dev/null || sleep 1
    done
    if ! tcp_socket_listening "$_port"; then
        _ping_cleanup
        err "temporary proxy listener did not start"
        return 1
    fi
    if [ "$_m" = "head" ]; then _label="via proxy (HEAD)"; set -- -I; else _label="via proxy (GET)"; set -- -X GET; fi
    # LC_ALL=C so curl prints time_total with a '.' decimal regardless of locale
    _out="$(LC_ALL=C curl -sS -o /dev/null -w '%{http_code} %{time_total}' --max-time "$PING_TIMEOUT" \
             "$@" --proxy "socks5h://127.0.0.1:${_port}" "$PING_URL" 2>/dev/null)" || _out=""
    _ping_cleanup
    if [ -z "$_out" ]; then c_red "${_label}: timeout (>${PING_TIMEOUT}s)"; return 1; fi
    _code="${_out%% *}"; _ms="$(_ms_from_seconds "${_out##* }")"
    case "$_code" in
        204|200) c_grn "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
        *)       c_ylw "${_label}: ${_ms} ms  (HTTP ${_code})" ;;
    esac
}

# host<TAB>port of the server to probe directly: the link's server, or (in pool
# mode, which has no single link) the first reachable server in the profile.
_ping_target_hp() {
    if [ "$(current_engine)" = "xraypool" ] && [ -f "$POOL_SRC" ]; then
        py "$MKJSON" firstserver --profile "$POOL_SRC" 2>/dev/null
    else
        _server_hp
    fi
}

ping_tcp() {
    _hp="$(_ping_target_hp)"
    _h="${_hp%%"$TAB"*}"; _p="${_hp#*"$TAB"}"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    ensure_service_user
    if have python3; then _ping_python=python3; else _ping_python=python; fi
    _ms="$(py "$SAFEEXEC" --user "$SERVICE_USER" --timeout "$((PING_TIMEOUT + 5))" \
        --memory-mb 128 --fsize-mb 1 -- "$_ping_python" - "$_h" "$_p" "$PING_TIMEOUT" <<'PYEOF'
import socket, time, sys
host, port, timeout = sys.argv[1], int(sys.argv[2]), float(sys.argv[3])
start = time.time()
try:
    socket.create_connection((host, port), timeout=timeout).close()
    print("%.0f" % ((time.time() - start) * 1000))
except Exception:
    sys.exit(1)
PYEOF
)" || { c_red "TCP ${_h}:${_p}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    c_grn "TCP ${_h}:${_p}: ${_ms} ms"
}

ping_icmp() {
    have ping || { err "ping is required for ICMP tests"; return 1; }
    _hp="$(_ping_target_hp)"
    _h="${_hp%%"$TAB"*}"
    [ -n "$_h" ] || { err "could not parse server from link"; return 1; }
    # '--' so a server host starting with '-' can't be read as a ping option
    ensure_service_user
    _out="$(py "$SAFEEXEC" --user "$SERVICE_USER" --timeout "$((PING_TIMEOUT + 5))" \
        --memory-mb 128 --fsize-mb 1 -- ping -c 1 -W "$PING_TIMEOUT" -- "$_h" 2>/dev/null)" \
        || { c_red "ICMP ${_h}: timeout (>${PING_TIMEOUT}s)"; return 1; }
    _ms="$(printf '%s\n' "$_out" | sed -n '/time=/{s/.*time=\([0-9.]*\).*/\1/p;q;}')"
    if [ -n "$_ms" ]; then c_grn "ICMP ${_h}: ${_ms} ms"; else c_red "ICMP ${_h}: no reply (host may block ICMP)"; fi
}

cmd_ping() {
    load_settings
    # pool mode keeps its config in $POOL_DIR (no single link file); a plain
    # link keeps $OUTBOUND_LINK. Either is pingable.
    if [ ! -f "$OUTBOUND_LINK" ] && [ "$(current_engine)" != "xraypool" ] \
        && [ "$(current_engine)" != "awg" ]; then
        c_ylw "No proxy/VPN imported yet. Add a link, subscription, JSON profile, or AmneziaWG profile first."
        return 1
    fi
    _mode="${1:-$PING_MODE}"
    case "$_mode" in
        get)  ping_proxy get ;;
        head) ping_proxy head ;;
        tcp)  ping_tcp ;;
        icmp) ping_icmp ;;
        *) fatal "unknown ping protocol '$_mode' (get|head|tcp|icmp)" ;;
    esac
}

# --------------------------------------------------------------------------
# Interactive menu (shown when `proxy` is run with no arguments)
# --------------------------------------------------------------------------
pause() { printf '\n'; printf 'Press Enter to return to the menu...'; read -r _ || true; }

print_menu() {
    load_settings
    # Build the 51-char box rule once (cached in the global $HR) with pure shell,
    # instead of spawning python on every redraw.
    if [ -z "${HR:-}" ]; then
        HR=""; _i=0
        while [ "$_i" -lt 51 ]; do HR="${HR}─"; _i=$((_i + 1)); done
    fi
    # is-active/is-enabled PRINT the state but EXIT non-zero for inactive/disabled,
    # so '|| echo ...' would append a second word. Capture stdout; default only
    # when it is empty (e.g. systemctl missing).
    svc="$(systemctl is-active "$SERVICE_NAME" 2>/dev/null)";  [ -n "$svc" ]  || svc=unknown
    auto="$(systemctl is-enabled "$SERVICE_NAME" 2>/dev/null)"; [ -n "$auto" ] || auto=disabled
    lst="down"; if socket_listening "$WG_PORT"; then lst="up"; fi
    ml() { printf '│ %-49s │\n' "$1"; }
    case "$svc" in active) svc_d="Running";; inactive) svc_d="Stopped";; *) svc_d="$svc";; esac
    case "$auto" in enabled) auto_d="Yes";; *) auto_d="No";; esac

    printf '\n'
    printf '┌%s┐\n' "$HR"
    ml "  0. Exit menu"
    printf '├%s┤\n' "$HR"
    ml "  1. Manage a single-server proxy link"
    ml "  2. Manage a multi-server subscription"
    printf '├%s┤\n' "$HR"
    ml "  3. Manage AmneziaWG profiles"
    printf '├%s┤\n' "$HR"
    ml "  4. Import an Xray JSON profile (from a file)"
    ml "  5. Show current server & config"
    printf '├%s┤\n' "$HR"
    ml "  6. Show UniFi WireGuard VPN Client config"
    ml "  7. Regenerate WireGuard keys"
    ml "  8. Change WireGuard settings"
    printf '├%s┤\n' "$HR"
    ml "  9. Ping test"
    ml " 10. Change test algorithm"
    printf '├%s┤\n' "$HR"
    ml " 11. Start"
    ml " 12. Stop"
    ml " 13. Restart"
    ml " 14. Check status"
    ml " 15. View logs"
    printf '├%s┤\n' "$HR"
    ml " 16. Enable autostart"
    ml " 17. Disable autostart"
    printf '├%s┤\n' "$HR"
    ml " 18. Update proxy cores"
    ml " 19. Update geo files"
    ml " 20. Version info"
    ml " 21. Uninstall"
    printf '└%s┘\n' "$HR"
    printf '\n'
    printf 'Service:    %s\n' "$svc_d"
    printf 'Autostart:  %s\n' "$auto_d"
    printf 'Listener:   udp %s (%s)\n' "$(wg_endpoint)" "$lst"
    printf 'Server:     %s\n' "$(current_server)"
}

# State-aware service controls used by the menu (idempotent feedback).
menu_start() {
    if systemctl is-active --quiet "$SERVICE_NAME" 2>/dev/null; then c_ylw "Service is already running."
    elif systemctl start "$SERVICE_NAME" 2>/dev/null;          then c_grn "Service started."
