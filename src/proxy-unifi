SUB_CATALOG="$SUB_DIR/catalog.json"         # cached parsed nodes
SUB_HWID_FILE="$SUB_DIR/hwid"               # stable per-install device id
SUB_SELECTED="$SUB_DIR/selected"            # id of the node currently activated
SUB_SELECTED_META="$SUB_DIR/selected.json"  # stable selection metadata for refresh matching
AWG_DIR="$ETC_DIR/awg"
AWG_PROFILES_DIR="$AWG_DIR/profiles"
