# Import a full Xray JSON profile (balancer / auto-select pool) from a file path.
menu_import_json() {
    echo "Provide the Xray JSON profile. Place the file on the gateway (e.g. via"
    echo "scp) and enter its path, or paste the JSON and end with a line of just EOF."
    printf 'File path (blank to paste instead): '
    read -r _p || true
    if [ -n "${_p:-}" ]; then
        [ -f "$_p" ] || { c_red "no such file: $_p"; return; }
        locked_call cmd_import_json "$_p"
        return
    fi
    ensure_run_dir
    _tmp="$RUN_DIR/pasted-profile.json"
    echo "Paste JSON now; finish with a single line containing only: EOF"
    while IFS= read -r _line; do
        [ "$_line" = "EOF" ] && break
        printf '%s\n' "$_line" >> "$_tmp"
    done
    if [ -s "$_tmp" ]; then locked_call cmd_import_json "$_tmp"; else c_ylw "Nothing pasted."; fi
    rm -f "$_tmp"
}

awg_secure_dirs() {
    mkdir -p "$AWG_PROFILES_DIR" "$AWG_DRAFT_DIR" \
        || fatal "could not create AmneziaWG profile directories"
    chmod 700 "$AWG_DIR" "$AWG_PROFILES_DIR" "$AWG_DRAFT_DIR" \
        || fatal "could not secure AmneziaWG profile directories"
}

awg_resolve() {
    _awg_resolve_id="$1"
    case "$_awg_resolve_id" in ????????-????-????-????-????????????) : ;; *) fatal "invalid profile id" ;; esac
    case "$_awg_resolve_id" in *[!0-9a-f-]*) fatal "invalid profile id" ;; esac
    if [ "${2:-}" = allow ]; then _awg_allow="--allow-invalid"; else _awg_allow=""; fi
    # shellcheck disable=SC2086 # optional fixed flag, never user-controlled.
    _awg_pick_row="$(PROXY_UNIFI_TERMINAL_SAFE_EMOJI=1 py "$MKAWG" pick \
        --dir "$AWG_PROFILES_DIR" --id "$_awg_resolve_id" $_awg_allow)" \
        || fatal "AmneziaWG profile no longer exists or is invalid"
    AWG_PICK_ID="${_awg_pick_row%%"$TAB"*}"
    _awg_pick_rest="${_awg_pick_row#*"$TAB"}"
    AWG_PICK_PATH="${_awg_pick_rest%%"$TAB"*}"
    AWG_PICK_NAME="${_awg_pick_rest#*"$TAB"}"
}

awg_list() {
    _awg_sel=""
    if [ "$(current_engine)" = awg ]; then
        _awg_sel="$(cat "$AWG_SELECTED" 2>/dev/null || true)"
    fi
    if [ -n "${1:-}" ]; then
        PROXY_UNIFI_TERMINAL_SAFE_EMOJI=1 py "$MKAWG" render \
            --dir "$AWG_PROFILES_DIR" --selected "$_awg_sel" --map-file "$1"
    else
        PROXY_UNIFI_TERMINAL_SAFE_EMOJI=1 py "$MKAWG" render \
            --dir "$AWG_PROFILES_DIR" --selected "$_awg_sel"
    fi
}

awg_choose() {
    _awg_choose_prompt="$1"; _awg_choose_mode="${2:-valid}"
    ensure_run_dir
    _awg_choose_map="$RUN_DIR/awg-choice.map"
    rm -f "$_awg_choose_map"
    awg_list "$_awg_choose_map" || return 1
    [ -s "$_awg_choose_map" ] || return 1
    echo
    printf '%s' "$_awg_choose_prompt"; read -r _awg_index || true
    case "${_awg_index:-}" in ""|*[!0-9]*) c_ylw "Cancelled."; return 1 ;; esac
    AWG_CHOICE_ID="$(awk -v n="$_awg_index" 'NR == n { print; exit }' "$_awg_choose_map")"
    [ -n "$AWG_CHOICE_ID" ] || { c_red "No profile #$_awg_index."; return 1; }
